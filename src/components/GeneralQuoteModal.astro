  async function downloadPDF() {
    if (Object.keys(selectedProducts).length === 0) {
      alert(lang === 'vi' ? 'Vui lòng chọn sản phẩm trước khi tải PDF' : lang === 'en' ? 'Please select products before downloading PDF' : '请在下载PDF之前选择产品')
      return
    }

    // Check if libraries are loaded
    if (typeof window.jspdf === 'undefined' || typeof window.html2canvas === 'undefined') {
      alert('PDF library is loading, please try again in a moment')
      return
    }

    try {
      // Show loading message
      const loadingMsg = lang === 'vi' ? 'Đang tạo PDF...' : lang === 'en' ? 'Generating PDF...' : '正在生成PDF...'
      const originalText = downloadPDFButton.textContent
      downloadPDFButton.textContent = loadingMsg
      downloadPDFButton.disabled = true

      // Get preview content
      const previewContentEl = document.getElementById('preview-content')
      if (!previewContentEl || !previewContentEl.firstElementChild) {
        showPreview()
        await new Promise(resolve => setTimeout(resolve, 100))
      }

      // Create a temporary container outside viewport for full rendering
      const tempContainer = document.createElement('div')
      tempContainer.style.position = 'absolute'
      tempContainer.style.left = '-9999px'
      tempContainer.style.top = '0'
      tempContainer.style.width = 'auto'
      tempContainer.style.height = 'auto'
      tempContainer.style.overflow = 'visible'
      
      // Clone the content
      const contentToClone = previewContentEl.firstElementChild
      const clonedContent = contentToClone.cloneNode(true)
      tempContainer.appendChild(clonedContent)
      document.body.appendChild(tempContainer)

      // Wait for fonts and images to load
      await new Promise(resolve => setTimeout(resolve, 200))

      // Convert HTML to canvas with full content
      const canvas = await html2canvas(tempContainer, {
        scale: 2,
        useCORS: true,
        logging: false,
        backgroundColor: '#ffffff',
        windowWidth: tempContainer.scrollWidth,
        windowHeight: tempContainer.scrollHeight
      })

      // Remove temporary container
      document.body.removeChild(tempContainer)

      // Create PDF with proper pagination
      const { jsPDF } = window.jspdf
      const imgData = canvas.toDataURL('image/png', 1.0)
      
      const pdf = new jsPDF({
        orientation: 'portrait',
        unit: 'mm',
        format: 'a4'
      })

      const pageWidth = 210
      const pageHeight = 297
      const imgWidth = pageWidth
      const imgHeight = (canvas.height * pageWidth) / canvas.width
      
      let position = 0
      
      // First page
      pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight)
      
      let heightLeft = imgHeight - pageHeight
      
      // Add additional pages if content is longer
      while (heightLeft > 0) {
        position = -pageHeight * (Math.ceil((imgHeight - heightLeft) / pageHeight))
        pdf.addPage()
        pdf.addImage(imgData, 'PNG', 0, position, imgWidth, imgHeight)
        heightLeft -= pageHeight
      }

      // Save PDF
      const filename = `BaoGia_QuangMinh_${new Date().getTime()}.pdf`
      pdf.save(filename)

      // Restore button
      downloadPDFButton.textContent = originalText
      downloadPDFButton.disabled = false

    } catch (error) {
      console.error('Error generating PDF:', error)
      alert(lang === 'vi' ? 'Có lỗi khi tạo PDF. Vui lòng thử lại.' : lang === 'en' ? 'Error generating PDF. Please try again.' : '生成PDF时出错。请重试。')
      downloadPDFButton.textContent = t.downloadPDF
      downloadPDFButton.disabled = false
    }
  }

  async function downloadPNG() {
    if (Object.keys(selectedProducts).length === 0) {
      alert(lang === 'vi' ? 'Vui lòng chọn sản phẩm trước khi tải PNG' : lang === 'en' ? 'Please select products before downloading PNG' : '请在下载PNG之前选择产品')
      return
    }

    // Check if html2canvas is loaded
    if (typeof window.html2canvas === 'undefined') {
      alert('PNG library is loading, please try again in a moment')
      return
    }

    try {
      // Show loading message
      const loadingMsg = lang === 'vi' ? 'Đang tạo PNG...' : lang === 'en' ? 'Generating PNG...' : '正在生成PNG...'
      const originalText = downloadPNGButton ? downloadPNGButton.textContent : ''
      if (downloadPNGButton) {
        downloadPNGButton.textContent = loadingMsg
        downloadPNGButton.disabled = true
      }

      // Get preview content
      const previewContentEl = document.getElementById('preview-content')
      if (!previewContentEl || !previewContentEl.firstElementChild) {
        showPreview()
        await new Promise(resolve => setTimeout(resolve, 100))
      }

      // Create a temporary container outside viewport for full rendering
      const tempContainer = document.createElement('div')
      tempContainer.style.position = 'absolute'
      tempContainer.style.left = '-9999px'
      tempContainer.style.top = '0'
      tempContainer.style.width = 'auto'
      tempContainer.style.height = 'auto'
      tempContainer.style.overflow = 'visible'
      
      // Clone the content
      const contentToClone = previewContentEl.firstElementChild
      const clonedContent = contentToClone.cloneNode(true)
      tempContainer.appendChild(clonedContent)
      document.body.appendChild(tempContainer)

      // Wait for fonts and images to load
      await new Promise(resolve => setTimeout(resolve, 200))

      // Convert HTML to canvas with full content
      const canvas = await html2canvas(tempContainer, {
        scale: 2,
        useCORS: true,
        logging: false,
        backgroundColor: '#ffffff',
        windowWidth: tempContainer.scrollWidth,
        windowHeight: tempContainer.scrollHeight
      })

      // Remove temporary container
      document.body.removeChild(tempContainer)

      // Convert canvas to PNG and download
      canvas.toBlob((blob) => {
        const url = URL.createObjectURL(blob)
        const link = document.createElement('a')
        link.href = url
        link.download = `BaoGia_QuangMinh_${new Date().getTime()}.png`
        document.body.appendChild(link)
        link.click()
        document.body.removeChild(link)
        URL.revokeObjectURL(url)

        // Restore button
        if (downloadPNGButton) {
          downloadPNGButton.textContent = originalText
          downloadPNGButton.disabled = false
        }
      }, 'image/png', 1.0)

    } catch (error) {
      console.error('Error generating PNG:', error)
      alert(lang === 'vi' ? 'Có lỗi khi tạo PNG. Vui lòng thử lại.' : lang === 'en' ? 'Error generating PNG. Please try again.' : '生成PNG时出错。请重试。')
      if (downloadPNGButton) {
        downloadPNGButton.textContent = t.downloadPNG
        downloadPNGButton.disabled = false
      }
    }
  }

  // Step 3 button handlers
  const downloadQuoteSuccess = document.getElementById('download-quote-success')
  const shareQuoteSuccess = document.getElementById('share-quote-success')
  const closeSuccess = document.getElementById('close-success')
  
  if (downloadQuoteSuccess) {
    downloadQuoteSuccess.addEventListener('click', () => {
      downloadPDF()
    })
  }
  
  if (shareQuoteSuccess) {
    shareQuoteSuccess.addEventListener('click', async () => {
      // Show loading state
      const originalText = shareQuoteSuccess.innerHTML
      shareQuoteSuccess.disabled = true
      shareQuoteSuccess.innerHTML = `
        <svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        <span>${lang === 'vi' ? 'Đang tạo...' : lang === 'en' ? 'Generating...' : '正在生成...'}</span>
      `
      
      try {
        const quoteNum = document.getElementById('quote-number')?.textContent || 'N/A'
        const customerEmail = document.getElementById('customer-email')?.textContent || ''
        
        // Share text with greeting from quote template
        const shareText = lang === 'vi' 
          ? `Kính gửi Quý khách hàng,\n\nCông ty Cổ phần Kỹ thuật và Công nghệ Quang Minh xin trân trọng gửi tới Quý khách hàng lời chào trân trọng nhất và lời cảm ơn chân thành về sự quan tâm, ủng hộ sản phẩm của chúng tôi.\n\nMã báo giá: ${quoteNum}\n\nTrân trọng!`
          : lang === 'en'
          ? `Dear Valued Customer,\n\nQuang Minh Technology Joint Stock Company would like to send our most sincere greetings and thanks for your interest and support of our products.\n\nQuote Reference: ${quoteNum}\n\nBest regards!`
          : `尊敬的客户，\n\nQuang Minh技术股份公司向您致以最诚挚的问候，感谢您对我们产品的关注和支持。\n\n报价编号: ${quoteNum}\n\n此致敬礼！`
        
        // Generate PNG file
        let pngFile = null
        
        if (typeof window.html2canvas !== 'undefined') {
          const htmlContent = generateQuotationHTML()
          const tempContainer = document.createElement('div')
          tempContainer.style.position = 'absolute'
          tempContainer.style.left = '-9999px'
          tempContainer.style.top = '0'
          tempContainer.innerHTML = htmlContent
          document.body.appendChild(tempContainer)
          
          await new Promise(resolve => setTimeout(resolve, 200))
          
          const canvas = await html2canvas(tempContainer, {
            scale: 2,
            useCORS: true,
            logging: false,
            backgroundColor: '#ffffff'
          })
          
          document.body.removeChild(tempContainer)
          
          const pngBlob = await new Promise(resolve => canvas.toBlob(resolve, 'image/png', 1.0))
          if (pngBlob) {
            pngFile = new File([pngBlob], `BaoGia_QuangMinh_${quoteNum}.png`, { type: 'image/png' })
          }
        }
        
        // Try Web Share API with file
        if (pngFile && navigator.canShare && navigator.canShare({ files: [pngFile] })) {
          await navigator.share({
            title: t.emailSubject,
            text: shareText,
            files: [pngFile]
          })
          showToast(
            lang === 'vi' ? 'Chia sẻ thành công!' : lang === 'en' ? 'Shared successfully!' : '分享成功！',
            'success'
          )
        } else if (navigator.share) {
          // Fallback: Share without file
          await navigator.share({
            title: t.emailSubject,
            text: shareText,
            url: window.location.href
          })
          showToast(
            lang === 'vi' ? 'Đã chia sẻ link' : lang === 'en' ? 'Link shared' : '已分享链接',
            'info'
          )
        } else {
          // Very old browsers - download file
          if (pngFile) {
            const url = URL.createObjectURL(pngFile)
            const link = document.createElement('a')
            link.href = url
            link.download = pngFile.name
            document.body.appendChild(link)
            link.click()
            document.body.removeChild(link)
            URL.revokeObjectURL(url)
            showToast(
              lang === 'vi' ? 'Đã tải file PNG' : lang === 'en' ? 'PNG downloaded' : 'PNG已下载',
              'success'
            )
          }
        }
      } catch (err) {
        console.error('Share error:', err)
        if (err.name !== 'AbortError') {
          showToast(
            lang === 'vi' ? 'Không thể chia sẻ' : lang === 'en' ? 'Cannot share' : '无法分享',
            'error'
          )
        }
      } finally {
        shareQuoteSuccess.disabled = false
        shareQuoteSuccess.innerHTML = originalText
      }
    })
  }
  
  if (closeSuccess) {
    closeSuccess.addEventListener('click', () => {
      closeModal()
    })
  }
</script>


