---
import { quoteModalTranslations } from '../data/quote-modal-translations'

interface Product {
  id: string
  name: string
  price: number | null
  unit: string
  specifications?: string
  image_url?: string
  image?: string
  imageUrl?: string
}

interface Props {
  lang?: 'vi' | 'en' | 'cn'
  products: Product[]
}

const { lang = 'vi', products = [] } = Astro.props

const t = quoteModalTranslations[lang]
const productsJson = JSON.stringify(products.map(p => ({ 
  id: p.id, 
  name: p.name, 
  price: p.price || 0, 
  unit: p.unit,
  specifications: p.specifications || '',
  image_url: p.image_url || ''
})))
---

<!-- General Quote Modal - Mobile Optimized -->
<div id="general-quote-modal" class="fixed inset-0 z-50 hidden items-center justify-center p-0 sm:p-4">
  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="general-modal-backdrop"></div>
  
  <div class="relative bg-white rounded-none sm:rounded-2xl shadow-2xl max-w-5xl w-full h-full sm:h-auto sm:max-h-[90vh] overflow-hidden flex flex-col">
    <!-- Sticky Header - Mobile Optimized -->
    <div class="sticky top-0 z-10 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 sm:py-4 safe-area-inset-top">
      <div class="flex items-center justify-between">
        <div class="flex-1 min-w-0">
          <h2 class="text-lg sm:text-xl font-semibold text-gray-900 truncate">{t.title}</h2>
          <p class="text-xs sm:text-sm text-gray-600 mt-0.5 sm:mt-1 truncate" id="step-subtitle">{t.step1}</p>
        </div>
        <button id="close-general-modal" class="flex-shrink-0 p-2 hover:bg-gray-100 rounded-lg transition-colors touch-manipulation ml-2" aria-label="Close modal">
          <svg class="w-6 h-6 sm:w-5 sm:h-5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      
      <!-- Progress - Desktop: Full view, Mobile: Compact -->
      <div class="flex items-center gap-2 mt-4">
        <!-- Desktop: Show all steps -->
        <div class="hidden sm:flex items-center gap-2 flex-1">
          <div class="w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center text-sm font-medium" id="step1-ind">1</div>
          <div class="text-sm font-medium text-gray-900">{t.step1}</div>
        </div>
        <div class="hidden sm:block w-12 h-0.5 bg-gray-200" id="progress-line-1"></div>
        <div class="hidden sm:flex items-center gap-2 flex-1">
          <div class="w-8 h-8 rounded-full bg-gray-200 text-gray-500 flex items-center justify-center text-sm font-medium" id="step2-ind">2</div>
          <div class="text-sm font-medium text-gray-500">{t.step2}</div>
        </div>
        <div class="hidden sm:block w-12 h-0.5 bg-gray-200" id="progress-line-2"></div>
        <div class="hidden sm:flex items-center gap-2 flex-1">
          <div class="w-8 h-8 rounded-full bg-gray-200 text-gray-500 flex items-center justify-center text-sm font-medium" id="step3-ind">3</div>
          <div class="text-sm font-medium text-gray-500">{t.step3}</div>
        </div>
        
        <!-- Mobile: Compact view - only current step -->
        <div class="flex sm:hidden items-center justify-center gap-3 w-full">
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-blue-600 text-white flex items-center justify-center text-sm font-medium" id="step-ind-mobile">1</div>
            <div class="text-sm font-medium text-gray-900" id="step-text-mobile">{t.step1}</div>
          </div>
          <div class="text-xs text-gray-500" id="step-count-mobile">1/3</div>
        </div>
      </div>
    </div>

    <div class="flex-1 overflow-y-auto">
      <!-- Step 1: Products -->
      <div id="step1-content" class="p-6" style="display:block">
        <!-- Tabs -->
        <div class="flex gap-2 mb-4 border-b border-gray-200">
          <button id="tab-custom" class="px-4 py-2 text-sm font-medium border-b-2 border-blue-600 text-blue-600 transition-colors">
            {t.tabCustom}
          </button>
          <button id="tab-capacity" class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-gray-600 hover:text-gray-900 transition-colors">
            {t.tabCapacity}
          </button>
        </div>

        <!-- Custom Quote Tab Content -->
        <div id="custom-content" style="display:block">
          <input type="text" id="product-search" placeholder={t.search} class="w-full px-4 py-2.5 border border-gray-300 rounded-lg mb-4 text-sm" />
          <div id="product-list" class="space-y-2 mb-4 max-h-64 overflow-y-auto"></div>
        </div>

        <!-- Capacity Quote Tab Content -->
        <div id="capacity-content" style="display:none">
          <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
            <p class="text-sm text-blue-800">{t.capacityNote}</p>
          </div>

          <!-- Quick capacity buttons -->
          <div class="mb-4">
            <label class="block text-sm font-medium text-gray-900 mb-2">{t.systemCapacity}</label>
            
            <!-- Mobile: 3 columns, 4 rows grid -->
            <div class="grid grid-cols-3 gap-2 md:hidden">
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation" data-capacity="5">5 kW</button>
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation" data-capacity="10">10 kW</button>
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation" data-capacity="20">20 kW</button>
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation" data-capacity="30">30 kW</button>
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation" data-capacity="50">50 kW</button>
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation" data-capacity="100">100 kW</button>
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation" data-capacity="200">200 kW</button>
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation" data-capacity="500">500 kW</button>
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation" data-capacity="1000">1 MW</button>
              <button type="button" class="capacity-btn px-3 py-2.5 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 active:scale-95 transition-all text-sm font-medium touch-manipulation col-span-3" data-capacity="custom">
                {lang === 'vi' ? 'Khác' : lang === 'en' ? 'Custom' : '自定义'}
              </button>
            </div>
            
            <!-- Desktop: Two rows, 5 columns grid -->
            <div class="hidden md:block">
              <div class="grid grid-cols-5 gap-2 mb-2">
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="5">5 kW</button>
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="10">10 kW</button>
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="20">20 kW</button>
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="30">30 kW</button>
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="50">50 kW</button>
              </div>
              <div class="grid grid-cols-5 gap-2">
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="100">100 kW</button>
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="200">200 kW</button>
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="500">500 kW</button>
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="1000">1 MW</button>
                <button type="button" class="capacity-btn px-4 py-2 border-2 border-gray-300 rounded-lg hover:border-blue-600 hover:bg-blue-50 transition-colors text-sm font-medium" data-capacity="custom">
                  {lang === 'vi' ? 'Khác' : lang === 'en' ? 'Custom' : '自定义'}
                </button>
              </div>
            </div>
          </div>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
            <div>
              <label class="block text-sm font-medium text-gray-900 mb-2">{t.systemCapacity} (kW)</label>
              <input 
                type="number" 
                id="system-capacity" 
                placeholder={t.capacityPlaceholder}
                min="1"
                step="0.1"
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent text-sm"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-900 mb-2">{t.panelType}</label>
              <select 
                id="panel-type" 
                class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent text-sm"
              >
                <option value="550">550W</option>
                <option value="600">600W</option>
                <option value="650">650W</option>
                <option value="700">700W</option>
              </select>
            </div>
          </div>

          <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 mb-4">
            <div class="flex justify-between items-center text-sm">
              <span class="text-blue-800">{t.panelCount}:</span>
              <span id="calculated-panels" class="font-semibold text-blue-900">0 tấm</span>
            </div>
          </div>

          <button id="calculate-capacity" class="w-full px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium mb-4">
            {t.autoCalculate}
          </button>

          <div id="capacity-result" class="space-y-2 max-h-64 overflow-y-auto"></div>
        </div>

        <!-- Summary (shared) -->
        <div class="bg-gray-50 rounded-lg p-4 border border-gray-200">
          <div id="selected-products" class="space-y-1 mb-2 text-sm max-h-32 overflow-y-auto">
            <p class="text-gray-500 text-center py-2">{t.noProducts}</p>
          </div>
          <div class="border-t border-gray-300 pt-2 space-y-1 text-sm">
            <div class="flex justify-between"><span>{t.total}:</span><span id="subtotal">0đ</span></div>
            <div class="flex justify-between"><span>{t.vat}:</span><span id="vat">0đ</span></div>
            <div class="flex justify-between font-semibold"><span>{t.grandTotal}:</span><span class="text-blue-600" id="grand-total">0đ</span></div>
          </div>
        </div>
      </div>

      <!-- Step 2: Contact Info -->
      <form id="general-quote-form" class="p-6 space-y-4" style="display:none" data-step="2">
      <div>
        <label class="block text-sm font-medium text-gray-900 mb-1">
          {t.name} <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          name="name"
          required
          placeholder={t.namePlaceholder}
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-900 mb-1">
          {t.phone} <span class="text-red-500">*</span>
        </label>
        <input
          type="tel"
          name="phone"
          required
          placeholder={t.phonePlaceholder}
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-900 mb-1">
          {t.email} <span class="text-red-500">*</span>
        </label>
        <input
          type="email"
          name="email"
          required
          placeholder={t.emailPlaceholder}
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm"
        />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-900 mb-1">
          {t.company}
        </label>
        <input type="text" name="company" placeholder={t.companyPlaceholder} class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm" />
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-900 mb-1">{t.message}</label>
        <textarea name="message" placeholder={t.messagePlaceholder} rows="3" class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all text-sm resize-none"></textarea>
      </div>
      </form>

      <!-- Step 3: Success -->
      <div id="step3-content" class="p-6" style="display:none">
        <div class="max-w-2xl mx-auto">
          <!-- Success Icon -->
          <div class="flex justify-center mb-6">
            <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center">
              <svg class="w-12 h-12 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
          </div>

          <!-- Success Title -->
          <h3 class="text-2xl font-bold text-center text-gray-900 mb-3">{t.successTitle}</h3>
          <p class="text-center text-gray-600 mb-6">{t.successMessage}</p>

          <!-- Customer Email Display -->
          <div class="bg-gradient-to-r from-green-50 to-emerald-50 border-2 border-green-300 rounded-xl p-5 mb-6">
            <div class="flex items-start gap-3">
              <div class="flex-shrink-0 w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div class="flex-1">
                <p class="text-sm font-medium text-green-800 mb-1">{t.yourEmail}:</p>
                <p class="text-base font-bold text-green-900 break-all" id="customer-email">customer@email.com</p>
              </div>
            </div>
          </div>

          <!-- Quote Info Card -->
          <div class="bg-gradient-to-br from-cyan-50 to-blue-50 rounded-xl p-6 mb-6 border border-cyan-200">
            <div class="space-y-3">
              <div class="flex items-center justify-between pb-3 border-b border-cyan-200">
                <span class="text-sm text-gray-600">{t.quoteNumber}:</span>
                <span class="text-base font-bold text-cyan-700" id="quote-number">QM-2025-001</span>
              </div>
              <div class="pt-2">
                <p class="text-sm font-semibold text-gray-700 mb-2">{t.supportTitle}:</p>
                <div class="space-y-2">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-600">{t.supportEmail}:</span>
                    <a href="mailto:info@qmalu.com" class="text-sm font-medium text-cyan-600 hover:text-cyan-700">info@qmalu.com</a>
                  </div>
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-gray-600">{t.supportPhone}:</span>
                    <a href="tel:0947776662" class="text-sm font-medium text-cyan-600 hover:text-cyan-700">0947 776 662</a>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Next Steps -->
          <div class="bg-white rounded-xl p-5 border border-gray-200 mb-6">
            <h4 class="text-lg font-semibold text-gray-900 mb-4">{t.nextSteps}:</h4>
            <div class="space-y-3">
              <div class="flex gap-3">
                <div class="flex-shrink-0 w-6 h-6 bg-cyan-100 rounded-full flex items-center justify-center">
                  <span class="text-xs font-bold text-cyan-700">1</span>
                </div>
                <p class="text-sm text-gray-700 flex-1 pt-0.5">{t.nextStep1}</p>
              </div>
              <div class="flex gap-3">
                <div class="flex-shrink-0 w-6 h-6 bg-cyan-100 rounded-full flex items-center justify-center">
                  <span class="text-xs font-bold text-cyan-700">2</span>
                </div>
                <p class="text-sm text-gray-700 flex-1 pt-0.5">{t.nextStep2}</p>
              </div>
              <div class="flex gap-3">
                <div class="flex-shrink-0 w-6 h-6 bg-cyan-100 rounded-full flex items-center justify-center">
                  <span class="text-xs font-bold text-cyan-700">3</span>
                </div>
                <p class="text-sm text-gray-700 flex-1 pt-0.5">{t.nextStep3}</p>
              </div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="space-y-3">
            <div class="grid grid-cols-2 gap-3">
              <button type="button" id="download-quote-success" class="px-4 py-3 bg-cyan-600 text-white rounded-lg hover:bg-cyan-700 transition-all text-sm font-medium flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <span>{t.downloadQuote}</span>
              </button>
              <button type="button" id="share-quote-success" class="px-4 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all text-sm font-medium flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z" />
                </svg>
                <span>{t.shareQuote}</span>
              </button>
            </div>
            <button type="button" id="close-success" class="w-full px-4 py-3 border-2 border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-all text-sm font-medium">
              {t.closeWindow}
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Sticky Footer - Mobile Optimized -->
    <div class="sticky bottom-0 border-t border-gray-200 px-4 sm:px-6 py-3 sm:py-4 bg-white safe-area-inset-bottom shadow-lg sm:shadow-none">
      <!-- Mobile: Simplified layout -->
      <div class="flex sm:hidden flex-col gap-2">
        <!-- Primary action row -->
        <div class="flex gap-2">
          <button type="button" id="back-button" class="hidden flex-1 px-4 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 active:scale-98 transition-all text-sm font-medium touch-manipulation">{t.back}</button>
          <button type="button" id="next-button" class="flex-1 px-4 py-3.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 active:scale-98 transition-all text-sm font-medium touch-manipulation">{t.next}</button>
          <button type="submit" id="submit-button" form="general-quote-form" class="hidden flex-1 px-4 py-3.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 active:scale-98 transition-all text-sm font-medium touch-manipulation">{t.submit}</button>
        </div>
        
        <!-- Download actions row -->
        <div class="flex gap-2">
          <button type="button" id="preview-quote-button" class="flex-1 px-3 py-2.5 border border-gray-600 text-gray-700 rounded-lg hover:bg-gray-50 active:scale-98 transition-all text-xs font-medium flex items-center justify-center gap-1.5 touch-manipulation">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            <span>Xem</span>
          </button>
          <button type="button" id="download-pdf-button" class="flex-1 px-3 py-2.5 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 active:scale-98 transition-all text-xs font-medium flex items-center justify-center gap-1.5 touch-manipulation">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <span>PDF</span>
          </button>
          <button type="button" id="download-png-button" class="flex-1 px-3 py-2.5 border border-green-600 text-green-600 rounded-lg hover:bg-green-50 active:scale-98 transition-all text-xs font-medium flex items-center justify-center gap-1.5 touch-manipulation">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span>PNG</span>
          </button>
        </div>
      </div>
      
      <!-- Desktop: Original layout -->
      <div class="hidden sm:flex gap-3">
        <button type="button" id="cancel-general-button" class="px-4 py-2.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">{t.cancel}</button>
        <button type="button" class="flex px-4 py-2.5 border border-gray-600 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium items-center gap-2" id="preview-quote-button-desktop">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
          {t.previewQuote}
        </button>
        <button type="button" class="flex px-4 py-2.5 border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 transition-colors text-sm font-medium items-center gap-2" id="download-pdf-button-desktop">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          {t.downloadPDF}
        </button>
        <button type="button" class="flex px-4 py-2.5 border border-green-600 text-green-600 rounded-lg hover:bg-green-50 transition-colors text-sm font-medium items-center gap-2" id="download-png-button-desktop">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          {t.downloadPNG}
        </button>
        <button type="button" id="back-button-desktop" class="hidden px-4 py-2.5 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors text-sm font-medium">{t.back}</button>
        <div class="flex flex-1"></div>
        <button type="button" id="next-button-desktop" class="hidden inline-block px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">{t.next}</button>
        <button type="submit" id="submit-button-desktop" form="general-quote-form" class="hidden inline-block px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium">{t.submit}</button>
      </div>
    </div>
  </div>
</div>

<!-- Preview Modal - Mobile Optimized -->
