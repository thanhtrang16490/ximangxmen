<!-- Load jsPDF and html2canvas from CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<script define:vars={{ productsJson, t }}>
  const products = JSON.parse(productsJson)
  const lang = t.title.includes('获取') ? 'cn' : t.title.includes('Request') ? 'en' : 'vi'
  let currentStep = 1
  let selectedProducts = {}
  let contactInfo = {}
  let currentTab = 'custom'

  const modal = document.getElementById('general-quote-modal')
  const closeButton = document.getElementById('close-general-modal')
  const cancelButton = document.getElementById('cancel-general-button')
  const backdrop = document.getElementById('general-modal-backdrop')
  const form = document.getElementById('general-quote-form')
  
  // Mobile buttons
  const nextButton = document.getElementById('next-button')
  const backButton = document.getElementById('back-button')
  const submitButton = document.getElementById('submit-button')
  const downloadPDFButton = document.getElementById('download-pdf-button')
  const downloadPNGButton = document.getElementById('download-png-button')
  const previewButton = document.getElementById('preview-quote-button')
  
  // Desktop buttons
  const nextButtonDesktop = document.getElementById('next-button-desktop')
  const backButtonDesktop = document.getElementById('back-button-desktop')
  const submitButtonDesktop = document.getElementById('submit-button-desktop')
  const downloadPDFButtonDesktop = document.getElementById('download-pdf-button-desktop')
  const downloadPNGButtonDesktop = document.getElementById('download-png-button-desktop')
  const previewButtonDesktop = document.getElementById('preview-quote-button-desktop')

  // Preview modal elements
  const previewModal = document.getElementById('preview-modal')
  const previewBackdrop = document.getElementById('preview-backdrop')
  const closePreviewModal = document.getElementById('close-preview-modal')
  const closePreviewButton = document.getElementById('close-preview-button')
  const downloadFromPreview = document.getElementById('download-from-preview')
  const downloadPNGFromPreview = document.getElementById('download-png-from-preview')
  const previewContent = document.getElementById('preview-content')

  const headerButton = document.getElementById('header-quote-button')
  const mobileButton = document.getElementById('mobile-quote-button')
  const footerButton = document.getElementById('footer-quote-button')
  const productButton = document.getElementById('quote-button')

  // Tab elements
  const tabCustom = document.getElementById('tab-custom')
  const tabCapacity = document.getElementById('tab-capacity')
  const customContent = document.getElementById('custom-content')
  const capacityContent = document.getElementById('capacity-content')
  const calculateBtn = document.getElementById('calculate-capacity')

  // Solar system calculation constants
  // Giả định: cần ~2 thanh ray, 4 kẹp giữa, 4 kẹp biên, 2 chân L per panel
  const MATERIALS_PER_PANEL = {
    '1': 2,    // Thanh Ray 26x45mm - 2 thanh/tấm
    '6': 4,    // Kẹp Giữa - 4 cái/tấm
    '7': 4,    // Kẹp Biên - 4 cái/tấm
    '9': 2,    // Chân L - 2 cái/tấm
    '4': 0.5,  // Thanh Nối Rail - 0.5 bộ/tấm
    '12': 1,   // Kẹp Tiếp Địa - 1 bộ/tấm
    '14': 2    // Lá Tiếp Địa - 2 cái/tấm
  }

  function openModal() {
    if (modal) {
      modal.classList.remove('hidden')
      modal.classList.add('flex')
      document.body.style.overflow = 'hidden'
      currentStep = 1
      currentTab = 'custom'
      showStep(1)
      switchTab('custom')
      renderProducts()
    }
  }

  function closeModal() {
    if (modal) {
      modal.classList.add('hidden')
      modal.classList.remove('flex')
      document.body.style.overflow = ''
      selectedProducts = {}
      if (form) form.reset()
      document.getElementById('system-capacity').value = ''
      document.getElementById('panel-type').value = '550'
      document.getElementById('calculated-panels').textContent = '0 tấm'
      document.getElementById('capacity-result').innerHTML = ''
    }
  }

  function switchTab(tab) {
    currentTab = tab
    if (tab === 'custom') {
      tabCustom.classList.add('border-blue-600', 'text-blue-600')
      tabCustom.classList.remove('border-transparent', 'text-gray-600')
      tabCapacity.classList.remove('border-blue-600', 'text-blue-600')
      tabCapacity.classList.add('border-transparent', 'text-gray-600')
      customContent.style.display = 'block'
      capacityContent.style.display = 'none'
    } else {
      tabCapacity.classList.add('border-blue-600', 'text-blue-600')
      tabCapacity.classList.remove('border-transparent', 'text-gray-600')
      tabCustom.classList.remove('border-blue-600', 'text-blue-600')
      tabCustom.classList.add('border-transparent', 'text-gray-600')
      customContent.style.display = 'none'
      capacityContent.style.display = 'block'
    }
  }

  function calculateByCapacity() {
    const capacityInput = document.getElementById('system-capacity')
    const panelTypeSelect = document.getElementById('panel-type')
    const calculatedPanelsEl = document.getElementById('calculated-panels')
    const resultDiv = document.getElementById('capacity-result')
    
    const capacity = parseFloat(capacityInput.value) || 0
    const panelWatt = parseInt(panelTypeSelect.value) || 550

    if (capacity === 0) {
      alert(lang === 'vi' ? 'Vui lòng nhập công suất hệ thống' : lang === 'en' ? 'Please enter system capacity' : '请输入系统容量')
      return
    }

    // Calculate panel count from capacity and panel type
    const panelCount = Math.ceil((capacity * 1000) / panelWatt)
    
    // Display calculated panel count
    const panelText = lang === 'vi' ? 'tấm' : lang === 'en' ? 'panels' : '块'
    calculatedPanelsEl.textContent = `${panelCount} ${panelText}`

    // Calculate materials
    selectedProducts = {}
    Object.entries(MATERIALS_PER_PANEL).forEach(([productId, qtyPerPanel]) => {
      const totalQty = Math.ceil(panelCount * qtyPerPanel)
      if (totalQty > 0) {
        selectedProducts[productId] = totalQty
      }
    })

    // Display result with editable quantities
    const items = Object.entries(selectedProducts).map(([id, qty]) => {
      const p = products.find(x => x.id === id)
      return p ? { ...p, quantity: qty } : null
    }).filter(Boolean)

    resultDiv.innerHTML = items.map(i => `
      <div class="flex items-center gap-2 p-2 bg-white border rounded hover:border-blue-300">
        <div class="flex-1">
          <div class="text-sm font-medium">${i.name}</div>
          <div class="text-xs text-gray-500">${i.price.toLocaleString('vi-VN')}đ/${i.unit}</div>
        </div>
        <div class="flex items-center gap-2">
          <div class="text-xs text-gray-500 w-12 text-center">${i.unit}</div>
          <input 
            type="number" 
            min="0" 
            value="${i.quantity}" 
            data-id="${i.id}" 
            class="w-20 px-2 py-1 border rounded text-sm text-center capacity-qty-input" 
          />
          <div class="text-sm font-medium text-blue-600 w-28 text-right capacity-item-total" data-id="${i.id}">
            ${(i.price * i.quantity).toLocaleString('vi-VN')}đ
          </div>
        </div>
      </div>
    `).join('')

    // Add event listeners to editable inputs
    document.querySelectorAll('.capacity-qty-input').forEach(input => {
      input.addEventListener('input', (e) => {
        const id = e.target.dataset.id
        const qty = parseInt(e.target.value) || 0
        if (qty > 0) {
          selectedProducts[id] = qty
        } else {
          delete selectedProducts[id]
        }
        updateCapacityItemTotal(id, qty)
        updateSummary()
      })
    })

    updateSummary()
  }

  function updateCapacityItemTotal(productId, quantity) {
    const product = products.find(p => p.id === productId)
    const totalEl = document.querySelector(`.capacity-item-total[data-id="${productId}"]`)
    if (product && totalEl) {
      const total = product.price * quantity
      totalEl.textContent = quantity > 0 ? total.toLocaleString('vi-VN') + 'đ' : '0đ'
    }
  }

  function showStep(step) {
    const step1 = document.getElementById('step1-content')
    const step2 = document.querySelector('[data-step="2"]')
    const step3 = document.getElementById('step3-content')
    const step1Ind = document.getElementById('step1-ind')
    const step2Ind = document.getElementById('step2-ind')
    const step3Ind = document.getElementById('step3-ind')
    const progressLine1 = document.getElementById('progress-line-1')
    const progressLine2 = document.getElementById('progress-line-2')
    const subtitle = document.getElementById('step-subtitle')
    
    // Mobile progress elements
    const stepIndMobile = document.getElementById('step-ind-mobile')
    const stepTextMobile = document.getElementById('step-text-mobile')
    const stepCountMobile = document.getElementById('step-count-mobile')

    // Hide all steps
    if (step1) step1.style.display = 'none'
    if (step2) step2.style.display = 'none'
    if (step3) step3.style.display = 'none'

    if (step === 1) {
      if (step1) step1.style.display = 'block'
      if (step1Ind) { step1Ind.classList.add('bg-blue-600', 'text-white'); step1Ind.classList.remove('bg-gray-200', 'text-gray-500', 'bg-green-600') }
      if (step2Ind) { step2Ind.classList.add('bg-gray-200', 'text-gray-500'); step2Ind.classList.remove('bg-blue-600', 'text-white') }
      if (step3Ind) { step3Ind.classList.add('bg-gray-200', 'text-gray-500'); step3Ind.classList.remove('bg-green-600', 'text-white') }
      if (progressLine1) { progressLine1.classList.remove('bg-blue-600'); progressLine1.classList.add('bg-gray-200') }
      if (progressLine2) { progressLine2.classList.remove('bg-green-600'); progressLine2.classList.add('bg-gray-200') }
      
      // Mobile progress
      if (stepIndMobile) {
        stepIndMobile.textContent = '1'
        stepIndMobile.classList.add('bg-blue-600', 'text-white')
        stepIndMobile.classList.remove('bg-gray-200', 'text-gray-500', 'bg-green-600')
      }
      if (stepTextMobile) stepTextMobile.textContent = t.step1
      if (stepCountMobile) stepCountMobile.textContent = '1/3'
      
      // Mobile buttons
      if (nextButton) nextButton.classList.remove('hidden')
      if (submitButton) submitButton.classList.add('hidden')
      if (backButton) backButton.classList.add('hidden')
      
      // Desktop buttons
      if (nextButtonDesktop) nextButtonDesktop.classList.remove('hidden')
      if (submitButtonDesktop) submitButtonDesktop.classList.add('hidden')
      if (backButtonDesktop) backButtonDesktop.classList.add('hidden')
      
      if (subtitle) subtitle.textContent = t.step1
    } else if (step === 2) {
      if (step2) step2.style.display = 'block'
      if (step2Ind) { step2Ind.classList.add('bg-blue-600', 'text-white'); step2Ind.classList.remove('bg-gray-200', 'text-gray-500') }
      if (step3Ind) { step3Ind.classList.add('bg-gray-200', 'text-gray-500'); step3Ind.classList.remove('bg-green-600', 'text-white') }
      if (progressLine1) { progressLine1.classList.add('bg-blue-600'); progressLine1.classList.remove('bg-gray-200') }
      if (progressLine2) { progressLine2.classList.remove('bg-green-600'); progressLine2.classList.add('bg-gray-200') }
      
      // Mobile progress
      if (stepIndMobile) {
        stepIndMobile.textContent = '2'
        stepIndMobile.classList.add('bg-blue-600', 'text-white')
        stepIndMobile.classList.remove('bg-gray-200', 'text-gray-500', 'bg-green-600')
      }
      if (stepTextMobile) stepTextMobile.textContent = t.step2
      if (stepCountMobile) stepCountMobile.textContent = '2/3'
      
      // Mobile buttons
      if (nextButton) nextButton.classList.add('hidden')
      if (submitButton) submitButton.classList.remove('hidden')
      if (backButton) backButton.classList.remove('hidden')
      
      // Desktop buttons
      if (nextButtonDesktop) nextButtonDesktop.classList.add('hidden')
      if (submitButtonDesktop) submitButtonDesktop.classList.remove('hidden')
      if (backButtonDesktop) backButtonDesktop.classList.remove('hidden')
      
      if (subtitle) subtitle.textContent = t.step2
    } else if (step === 3) {
      if (step3) step3.style.display = 'block'
      if (step3Ind) { step3Ind.classList.add('bg-green-600', 'text-white'); step3Ind.classList.remove('bg-gray-200', 'text-gray-500') }
      if (progressLine1) { progressLine1.classList.add('bg-blue-600'); progressLine1.classList.remove('bg-gray-200') }
      if (progressLine2) { progressLine2.classList.add('bg-green-600'); progressLine2.classList.remove('bg-gray-200') }
      
      // Mobile progress
      if (stepIndMobile) {
        stepIndMobile.textContent = '3'
        stepIndMobile.classList.add('bg-green-600', 'text-white')
        stepIndMobile.classList.remove('bg-gray-200', 'text-gray-500', 'bg-blue-600')
      }
      if (stepTextMobile) stepTextMobile.textContent = t.step3
      if (stepCountMobile) stepCountMobile.textContent = '3/3'
      
      // Mobile buttons
      if (nextButton) nextButton.classList.add('hidden')
      if (submitButton) submitButton.classList.add('hidden')
      if (backButton) backButton.classList.add('hidden')
      
      // Desktop buttons
      if (nextButtonDesktop) nextButtonDesktop.classList.add('hidden')
      if (submitButtonDesktop) submitButtonDesktop.classList.add('hidden')
      if (backButtonDesktop) backButtonDesktop.classList.add('hidden')
      
      if (subtitle) subtitle.textContent = t.step3
      
      // Generate quote number
      const quoteNum = `QM-${new Date().getFullYear()}-${String(new Date().getMonth() + 1).padStart(2, '0')}${String(new Date().getDate()).padStart(2, '0')}-${Math.floor(Math.random() * 1000).toString().padStart(3, '0')}`
      const quoteNumberEl = document.getElementById('quote-number')
      if (quoteNumberEl) quoteNumberEl.textContent = quoteNum
      
      // Display customer email
      const customerEmailEl = document.getElementById('customer-email')
      if (customerEmailEl && contactInfo.email) {
        customerEmailEl.textContent = contactInfo.email
      }
    }
  }

  function renderProducts() {
    const list = document.getElementById('product-list')
    if (!list) return
    list.innerHTML = products.map(p => `
      <div class="flex items-center gap-2 p-2 border rounded hover:border-blue-300 product-item">
        <div class="flex-1">
          <div class="text-sm font-medium">${p.name}</div>
          <div class="text-xs text-gray-500">${p.price.toLocaleString('vi-VN')}đ/${p.unit}</div>
        </div>
        <div class="flex items-center gap-2">
          <div class="text-xs text-gray-500 w-12 text-center">${p.unit}</div>
          <input type="number" min="0" value="${selectedProducts[p.id] || 0}" data-id="${p.id}" class="w-20 px-2 py-1 border rounded text-sm text-center qty-input" />
          <div class="text-sm font-medium text-blue-600 w-28 text-right item-total" data-id="${p.id}">0đ</div>
        </div>
      </div>
    `).join('')

    document.querySelectorAll('.qty-input').forEach(input => {
      input.addEventListener('input', (e) => {
        const id = e.target.dataset.id
        const qty = parseInt(e.target.value) || 0
        if (qty > 0) selectedProducts[id] = qty
        else delete selectedProducts[id]
        updateItemTotal(id, qty)
        updateSummary()
      })
    })
    
    // Update initial totals
    Object.entries(selectedProducts).forEach(([id, qty]) => {
      updateItemTotal(id, qty)
    })
  }

  function updateItemTotal(productId, quantity) {
    const product = products.find(p => p.id === productId)
    const totalEl = document.querySelector(`.item-total[data-id="${productId}"]`)
    if (product && totalEl) {
      const total = product.price * quantity
      totalEl.textContent = quantity > 0 ? total.toLocaleString('vi-VN') + 'đ' : '0đ'
    }
  }

  function updateSummary() {
    const div = document.getElementById('selected-products')
    const subtotalEl = document.getElementById('subtotal')
    const vatEl = document.getElementById('vat')
    const grandTotalEl = document.getElementById('grand-total')
    if (!div) return

    const items = Object.entries(selectedProducts).map(([id, qty]) => {
      const p = products.find(x => x.id === id)
      return p ? { ...p, quantity: qty } : null
    }).filter(Boolean)

    if (items.length === 0) {
