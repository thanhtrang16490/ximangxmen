  <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" id="preview-backdrop"></div>
  
  <div class="relative bg-white rounded-none sm:rounded-2xl shadow-2xl max-w-4xl w-full h-full sm:h-auto sm:max-h-[90vh] overflow-hidden flex flex-col">
    <div class="sticky top-0 z-10 bg-white border-b border-gray-200 px-4 sm:px-6 py-3 sm:py-4 flex items-center justify-between safe-area-inset-top">
