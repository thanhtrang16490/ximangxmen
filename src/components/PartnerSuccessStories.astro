---
const stories = [
  {
    name: 'Đại lý Thành Đạt',
    location: 'Hà Nam',
    avatar: '👨‍💼',
    type: 'Đại lý cấp 1',
    years: '5 năm',
    stats: [
      { label: 'Doanh số/tháng', value: '500+ tấn' },
      { label: 'Tăng trưởng', value: '+150%' },
      { label: 'Khách hàng', value: '200+' }
    ],
    quote: 'Từ khi hợp tác với Quang Minh, doanh số của chúng tôi tăng gấp 2.5 lần. Chất lượng sản phẩm ổn định, chính sách hỗ trợ tốt, đội ngũ kỹ thuật nhiệt tình.',
    image: '📈'
  },
  {
    name: 'Công ty TNHH Phú Thịnh',
    location: 'Nam Định',
    avatar: '👩‍💼',
    type: 'Nhà phân phối',
    years: '3 năm',
    stats: [
      { label: 'Doanh số/tháng', value: '800+ tấn' },
      { label: 'Mạng lưới', value: '50 đại lý' },
      { label: 'Vùng phủ', value: '5 tỉnh' }
    ],
    quote: 'Quang Minh là đối tác tin cậy nhất của chúng tôi. Sản phẩm chất lượng cao, giá cạnh tranh, hỗ trợ marketing và đào tạo rất chuyên nghiệp.',
    image: '🏆'
  },
  {
    name: 'Hợp tác xã Nông nghiệp Hòa Bình',
    location: 'Thái Bình',
    avatar: '🤝',
    type: 'Hợp tác xã',
    years: '4 năm',
    stats: [
      { label: 'Thành viên', value: '150+' },
      { label: 'Tiết kiệm', value: '30%' },
      { label: 'Năng suất', value: '+40%' }
    ],
    quote: 'Nhờ chuyển sang dùng thức ăn Quang Minh, các thành viên HTX tiết kiệm được 30% chi phí, năng suất tăng rõ rệt. Đội ngũ kỹ thuật thường xuyên xuống tận nơi hỗ trợ.',
    image: '🌾'
  }
]
---

<section class="py-32 px-4 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-white via-blue-50/30 to-white"></div>
  
  <!-- Animated gradient mesh -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-1/4 right-1/3 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
    <div class="absolute bottom-1/4 left-1/3 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
  </div>
  
  <div class="container mx-auto relative z-10">
    <!-- Header -->
    <div class="text-center mb-20 scroll-reveal">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-primary tracking-wide uppercase bg-red-50 px-4 py-2 rounded-full">
          Câu chuyện thành công
        </span>
      </div>
      <h2 class="text-5xl md:text-6xl font-semibold text-gray-900 mb-6 tracking-tight">
        Đối tác thành công
      </h2>
      <p class="text-xl md:text-2xl text-gray-600 max-w-3xl mx-auto font-light leading-relaxed">
        Hàng trăm đại lý và đối tác đã phát triển mạnh mẽ<br class="hidden md:block" />
        cùng Quang Minh trong những năm qua
      </p>
    </div>

    <!-- Stories Grid -->
    <div class="grid md:grid-cols-3 gap-8 max-w-7xl mx-auto">
      {stories.map((story, index) => (
        <div 
          class="group bg-white rounded-3xl overflow-hidden hover:shadow-2xl transition-all duration-500 scroll-reveal"
          style={`animation-delay: ${index * 0.15}s`}
        >
          <!-- Header Card -->
          <div class="bg-gradient-to-br from-primary to-blue-700 p-8 text-white relative overflow-hidden">
            <!-- Background Pattern -->
            <div class="absolute inset-0 opacity-10">
              <div class="absolute top-0 right-0 text-9xl transform translate-x-1/4 -translate-y-1/4">
                {story.image}
              </div>
            </div>
            
            <div class="relative z-10">
              <!-- Avatar -->
              <div class="text-6xl mb-4">{story.avatar}</div>
              
              <!-- Name & Location -->
              <h3 class="text-2xl font-semibold mb-2 tracking-tight">
                {story.name}
              </h3>
              <div class="flex items-center gap-2 text-blue-100 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span class="text-sm">{story.location}</span>
              </div>
              
              <!-- Type & Years -->
              <div class="flex gap-2">
                <span class="text-xs bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full">
                  {story.type}
                </span>
                <span class="text-xs bg-white/20 backdrop-blur-sm px-3 py-1 rounded-full">
                  {story.years}
                </span>
              </div>
            </div>
          </div>

          <!-- Stats -->
          <div class="p-6 border-b border-gray-100">
            <div class="grid grid-cols-3 gap-4">
              {story.stats.map(stat => (
                <div class="text-center">
                  <div class="text-2xl font-bold text-primary mb-1">
                    {stat.value}
                  </div>
                  <div class="text-xs text-gray-600">
                    {stat.label}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Quote -->
          <div class="p-8">
            <div class="flex gap-2 mb-3">
              {[...Array(5)].map((_, i) => (
                <svg key={i} class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-gray-700 leading-relaxed italic">
              "{story.quote}"
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-16 scroll-reveal">
      <div class="bg-gradient-to-br from-blue-50 to-blue-50 rounded-3xl p-10 max-w-4xl mx-auto">
        <h3 class="text-3xl font-semibold text-gray-900 mb-4">
          Bạn cũng có thể thành công như họ
        </h3>
        <p class="text-lg text-gray-600 mb-6">
          Hãy để Quang Minh đồng hành cùng bạn trên con đường phát triển kinh doanh
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/lien-he"
            class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-8 py-4 rounded-full font-semibold text-lg transition-all shadow-lg hover:shadow-xl transform hover:scale-105"
          >
            Đăng ký trở thành đại lý
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a 
            href="tel:+84962352394"
            class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-900 px-8 py-4 rounded-full font-semibold text-lg transition-all shadow-md hover:shadow-lg border-2 border-gray-200"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Gọi ngay: 035 135 9520
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
