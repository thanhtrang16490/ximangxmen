---
const regions = [
  {
    name: 'Miền Bắc',
    provinces: [
      { name: 'Hà Nội', dealers: 15, icon: '🏛️' },
      { name: 'Hà Nam', dealers: 8, icon: '🏭', highlight: true },
      { name: 'Nam Định', dealers: 12, icon: '🏪' },
      { name: 'Thái Bình', dealers: 10, icon: '🏪' },
      { name: 'Ninh Bình', dealers: 6, icon: '🏪' },
      { name: 'Hải Phòng', dealers: 9, icon: '⚓' }
    ],
    color: 'from-blue-500 to-primary'
  },
  {
    name: 'Miền Trung',
    provinces: [
      { name: 'Thanh Hóa', dealers: 14, icon: '🏪' },
      { name: 'Nghệ An', dealers: 11, icon: '🏪' },
      { name: 'Hà Tĩnh', dealers: 7, icon: '🏪' },
      { name: 'Quảng Bình', dealers: 5, icon: '🏪' },
      { name: 'Đà Nẵng', dealers: 8, icon: '🌊' }
    ],
    color: 'from-green-500 to-green-600'
  },
  {
    name: 'Miền Nam',
    provinces: [
      { name: 'TP. Hồ Chí Minh', dealers: 20, icon: '🏙️' },
      { name: 'Đồng Nai', dealers: 13, icon: '🏪' },
      { name: 'Bình Dương', dealers: 15, icon: '🏪' },
      { name: 'Long An', dealers: 9, icon: '🏪' },
      { name: 'Cần Thơ', dealers: 10, icon: '🌾' }
    ],
    color: 'from-orange-500 to-orange-600'
  }
]

const totalDealers = regions.reduce((sum, region) => 
  sum + region.provinces.reduce((s, p) => s + p.dealers, 0), 0
)
---

<section class="py-32 px-4 relative overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-gray-50 via-white to-blue-50"></div>
  
  <!-- Animated gradient mesh -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
    <div class="absolute bottom-1/3 right-1/4 w-96 h-96 bg-green-400 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
  </div>
  
  <div class="container mx-auto relative z-10">
    <!-- Header -->
    <div class="text-center mb-20 scroll-reveal">
      <div class="inline-block mb-4">
        <span class="text-sm font-semibold text-primary tracking-wide uppercase bg-red-50 px-4 py-2 rounded-full">
          Tìm đại lý gần bạn
        </span>
      </div>
      <h2 class="text-5xl md:text-6xl font-semibold text-gray-900 mb-6 tracking-tight">
        Hệ thống đại lý toàn quốc
      </h2>
      <p class="text-xl md:text-2xl text-gray-600 max-w-3xl mx-auto font-light leading-relaxed">
        Hơn <span class="font-semibold text-primary">{totalDealers}+ đại lý</span> trên toàn quốc<br class="hidden md:block" />
        sẵn sàng phục vụ và tư vấn cho bạn
      </p>
    </div>

    <!-- Regions Grid -->
    <div class="grid md:grid-cols-3 gap-8 max-w-7xl mx-auto mb-16">
      {regions.map((region, index) => (
        <div 
          class="bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500 scroll-reveal"
          style={`animation-delay: ${index * 0.15}s`}
        >
          <!-- Header -->
          <div class={`bg-gradient-to-br ${region.color} p-6 text-white`}>
            <h3 class="text-2xl font-semibold mb-2">{region.name}</h3>
            <p class="text-sm opacity-90">
              {region.provinces.reduce((sum, p) => sum + p.dealers, 0)} đại lý
            </p>
          </div>

          <!-- Provinces List -->
          <div class="p-6 space-y-3">
            {region.provinces.map(province => (
              <div class={`flex items-center justify-between p-3 rounded-xl transition-all ${
                province.highlight 
                  ? 'bg-red-50 border-2 border-blue-200' 
                  : 'hover:bg-gray-50'
              }`}>
                <div class="flex items-center gap-3">
                  <span class="text-2xl">{province.icon}</span>
                  <div>
                    <div class="font-semibold text-gray-900 flex items-center gap-2">
                      {province.name}
                      {province.highlight && (
                        <span class="text-xs bg-primary text-white px-2 py-0.5 rounded-full">
                          Nhà máy
                        </span>
                      )}
                    </div>
                    <div class="text-sm text-gray-600">
                      {province.dealers} đại lý
                    </div>
                  </div>
                </div>
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- How to Buy Section -->
    <div class="max-w-5xl mx-auto scroll-reveal">
      <div class="bg-gradient-to-br from-blue-50 to-green-50 rounded-3xl p-10">
        <h3 class="text-3xl font-semibold text-gray-900 mb-8 text-center">
          Cách mua hàng
        </h3>
        
        <div class="grid md:grid-cols-3 gap-8">
          <!-- Step 1 -->
          <div class="text-center">
            <div class="w-20 h-20 bg-white rounded-2xl shadow-lg flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl">🔍</span>
            </div>
            <div class="text-6xl font-bold text-primary mb-2">1</div>
            <h4 class="text-xl font-semibold text-gray-900 mb-2">
              Tìm đại lý gần bạn
            </h4>
            <p class="text-gray-600">
              Liên hệ hotline hoặc website để tìm đại lý gần nhất
            </p>
          </div>

          <!-- Step 2 -->
          <div class="text-center">
            <div class="w-20 h-20 bg-white rounded-2xl shadow-lg flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl">💬</span>
            </div>
            <div class="text-6xl font-bold text-green-600 mb-2">2</div>
            <h4 class="text-xl font-semibold text-gray-900 mb-2">
              Tư vấn trực tiếp
            </h4>
            <p class="text-gray-600">
              Đại lý tư vấn sản phẩm phù hợp với nhu cầu của bạn
            </p>
          </div>

          <!-- Step 3 -->
          <div class="text-center">
            <div class="w-20 h-20 bg-white rounded-2xl shadow-lg flex items-center justify-center mx-auto mb-4">
              <span class="text-4xl">🚚</span>
            </div>
            <div class="text-6xl font-bold text-orange-600 mb-2">3</div>
            <h4 class="text-xl font-semibold text-gray-900 mb-2">
              Nhận hàng tận nơi
            </h4>
            <p class="text-gray-600">
              Đại lý giao hàng tận xưởng sản xuất, hỗ trợ kỹ thuật
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16 scroll-reveal">
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="/lien-he"
          class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-8 py-4 rounded-full font-semibold text-lg transition-all shadow-lg hover:shadow-xl transform hover:scale-105"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Tìm đại lý gần bạn
        </a>
        <a 
          href="tel:+84962916488"
          class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-900 px-8 py-4 rounded-full font-semibold text-lg transition-all shadow-md hover:shadow-lg border-2 border-gray-200"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Hotline: 035 135 9520
        </a>
      </div>
      <p class="text-sm text-gray-500 mt-4">
        Hoặc để lại thông tin, chúng tôi sẽ kết nối bạn với đại lý gần nhất
      </p>
    </div>
  </div>
</section>
