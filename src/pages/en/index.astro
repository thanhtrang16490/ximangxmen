    import { initScrollParallax, initMouseParallax } from '../../lib/parallax';
    import { initMagneticButtons } from '../../lib/magnetic-buttons';
    import { initMobileFeatures } from '../../lib/mobile-features';
    // import { initCustomCursor } from '../../lib/custom-cursor'; // Temporarily disabled
    import { startPerformanceMonitoring } from '../../lib/performance-monitor';
    
