---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Hero3DBackground from '../../components/Hero3DBackground'
import DNA3DHelix from '../../components/DNA3DHelix'
import ParticleWave3D from '../../components/ParticleWave3D'
import AnimatedSphere3D from '../../components/AnimatedSphere3D'
import AnimatedCounter from '../../components/AnimatedCounter'
import CertificatesAndPartners from '../../components/CertificatesAndPartners'
import CaseStudies from '../../components/CaseStudies'
import InteractiveMap from '../../components/InteractiveMap'
import ScrollProgress from '../../components/ScrollProgress.astro'
import MobileQuoteFAB from '../../components/MobileQuoteFAB'
import GeneralQuoteModal from '../../components/GeneralQuoteModal.astro'
import { companyInfoEn as companyInfo } from '../../data/company-info'
import { homepageContentEn as homepageContent } from '../../data/homepage-content-en'
import { caseStudiesEn as caseStudies } from '../../data/case-studies'
import { homepageStaticEn } from '../../data/homepage-static-en'
import { getProducts } from '../../lib/supabase'

// Fetch products for quote modal
const allProducts = await getProducts()

const seoTitle = homepageStaticEn.seo.title
const seoDescription = homepageStaticEn.seo.description
const seoKeywords = homepageStaticEn.seo.keywords

const stats = homepageStaticEn.stats

const testimonials = homepageStaticEn.testimonials

const faqs = homepageStaticEn.faqs



const products = homepageStaticEn.products

const pricePreview = homepageStaticEn.pricePreview

const whyChooseUs = homepageStaticEn.whyChooseUs
---

<BaseLayout 
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  ogImage="/nha-may.png"
  canonical="/en/"
>
  <ScrollProgress />
  <div class="min-h-screen bg-white">
  <!-- Hero Section - Apple Style -->
  <section class="min-h-screen md:min-h-screen flex items-center justify-center px-4 pt-24 pb-20 relative overflow-hidden" id="hero-section" style="min-height: 80vh;">
    <!-- 3D Enhanced Background - client:only for SSR compatibility - Desktop only -->
    <div class="absolute inset-0 opacity-20 desktop-only" data-parallax="0.3">
      <Hero3DBackground client:only="react" />
    </div>
    
    <!-- Simple overlay -->
    <div class="absolute inset-0 bg-neutral-50/80" data-parallax="0.4"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-white/90 via-transparent to-transparent"></div>
    
    <!-- Radial gradient spotlight -->
    <div class="absolute inset-0 bg-radial-gradient" data-parallax="0.5"></div>
    
    <!-- Animated gradient mesh with parallax -->
    <div class="absolute inset-0 opacity-30" data-parallax="0.6">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-400 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
      <div class="absolute top-0 right-1/4 w-96 h-96 bg-green-400 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
      <div class="absolute bottom-0 left-1/3 w-96 h-96 bg-indigo-400 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-4000"></div>
    </div>
    
    <div class="container mx-auto text-center relative z-10">
      <!-- New Badge -->
      <div class="mb-6 opacity-0 hero-fade-in" style="animation-delay: 0.1s">
        <div class="inline-flex items-center gap-2 bg-gradient-to-r from-primary to-green-600 text-white px-5 py-2.5 rounded-full text-sm font-bold shadow-lg">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span>{homepageStaticEn.htmlContent.heroBadge}</span>
        </div>
      </div>
      
      <!-- Main Heading - Value Proposition -->
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-gray-900 mb-6 leading-[1.1] opacity-0 hero-fade-in tracking-tight" style="animation-delay: 0.3s" data-depth="0.3">
        {homepageStaticEn.htmlContent.heroTitle}<br />
        {homepageStaticEn.htmlContent.heroTitleHighlight} <span class="text-primary">MWp</span>
      </h1>
      
      <!-- Subheading - Clear Benefits -->
      <p class="text-xl md:text-2xl lg:text-3xl text-gray-700 mb-4 max-w-4xl mx-auto leading-relaxed opacity-0 hero-fade-in font-medium" style="animation-delay: 0.5s" data-depth="0.2">
        {homepageStaticEn.htmlContent.heroSubtitle}
      </p>
      
      <div class="flex flex-col md:flex-row md:flex-wrap md:justify-center gap-3 md:gap-0 text-base md:text-lg lg:text-xl text-gray-600 mb-10 max-w-3xl mx-auto opacity-0 hero-fade-in font-light" style="animation-delay: 0.6s">
        {homepageStaticEn.hero.benefits.map((benefit) => (
          <span class="flex items-center gap-2 md:mx-2">
            <svg class="w-5 h-5 flex-shrink-0 text-green-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>{benefit}</span>
          </span>
        ))}
      </div>
      
      <!-- Enhanced CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center opacity-0 hero-fade-in mb-16" style="animation-delay: 0.8s">
        <a 
          href="/en/contact"
          class="magnetic-button group bg-primary hover:bg-primary-dark text-white px-10 py-5 rounded-full font-semibold text-lg transition-all inline-flex items-center justify-center gap-3 shadow-lg hover:shadow-xl"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span>{homepageStaticEn.hero.cta.primary}</span>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a 
          href="#production-capacity"
          class="magnetic-button group bg-white hover:bg-gray-50 text-gray-900 px-10 py-5 rounded-full font-bold text-lg border-2 border-gray-300 hover:border-gray-400 transition-all inline-flex items-center justify-center gap-3 shadow-lg hover:shadow-xl hover:scale-105 transform"
        >
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
          <span>{homepageStaticEn.htmlContent.ctaSecondary}</span>
        </a>
      </div>
      
      <!-- Enhanced Trust Indicators with Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-6 max-w-5xl mx-auto opacity-0 hero-fade-in" style="animation-delay: 1s">
        <div class="bg-white/95 backdrop-blur-md rounded-xl md:rounded-2xl p-4 md:p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-all">
          <div class="flex items-center justify-center mb-2 md:mb-3">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-green-50 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 md:w-8 md:h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
          <div class="text-xl md:text-2xl font-bold text-gray-900 mb-1">ISO 9001</div>
          <div class="text-xs md:text-sm text-gray-600 font-medium">International Certification</div>
        </div>
        
        <div class="bg-white/95 backdrop-blur-md rounded-xl md:rounded-2xl p-4 md:p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-all">
          <div class="flex items-center justify-center mb-2 md:mb-3">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-red-50 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 md:w-8 md:h-8 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
          <div class="text-xl md:text-2xl font-bold text-gray-900 mb-1">16+ years</div>
          <div class="text-xs md:text-sm text-gray-600 font-medium">Years Experience</div>
        </div>
        
        <div class="bg-white/95 backdrop-blur-md rounded-xl md:rounded-2xl p-4 md:p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-all">
          <div class="flex items-center justify-center mb-2 md:mb-3">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-neutral-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 md:w-8 md:h-8 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
              </svg>
            </div>
          </div>
          <div class="text-xl md:text-2xl font-bold text-gray-900 mb-1">1,500+</div>
          <div class="text-xs md:text-sm text-gray-600 font-medium">Customers</div>
        </div>
        
        <div class="bg-white/95 backdrop-blur-md rounded-xl md:rounded-2xl p-4 md:p-6 shadow-lg border border-gray-200 hover:shadow-xl transition-all">
          <div class="flex items-center justify-center mb-2 md:mb-3">
            <div class="w-12 h-12 md:w-14 md:h-14 bg-neutral-100 rounded-full flex items-center justify-center">
              <svg class="w-6 h-6 md:w-8 md:h-8 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          </div>
          <div class="text-xl md:text-2xl font-bold text-gray-900 mb-1">Export</div>
          <div class="text-xs md:text-sm text-gray-600 font-medium">Southeast Asia & Europe</div>
        </div>
      </div>
      
      <!-- Scroll indicator with animation -->
      <div class="mt-16 opacity-0 hero-fade-in scroll-indicator" style="animation-delay: 1.2s">
        <div class="flex flex-col items-center gap-2">
          <div class="w-6 h-10 border-2 border-gray-400 rounded-full flex items-start justify-center p-2 hover:border-gray-600 transition-colors cursor-pointer">
            <div class="w-1.5 h-3 bg-gray-500 rounded-full animate-bounce"></div>
          </div>
          <span class="text-xs text-gray-500 font-semibold tracking-wide uppercase">Discover More</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Urgency Banner - B2B Focus -->
  <section class="py-4 px-4 bg-primary relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 left-0 w-96 h-96 bg-white rounded-full filter blur-3xl animate-pulse"></div>
    </div>
    <div class="container mx-auto relative z-10">
      <div class="flex flex-col md:flex-row items-center justify-center gap-4 text-white text-center">
        <div class="flex items-center gap-2">
          <svg class="w-6 h-6 animate-bounce" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
          </svg>
          <span class="text-lg md:text-xl font-bold">⚡ Trusted Partner for EPC Projects</span>
        </div>
        <div class="text-base md:text-lg font-semibold">
          Professional Technical Support • On-time Delivery • Quality Commitment
        </div>
      </div>
    </div>
  </section>

  <!-- Company Introduction Section - NEW B2B Feature -->
  <section class="py-16 md:py-20 px-4 relative overflow-hidden bg-gradient-to-b from-white to-gray-50/40">
    <div class="container mx-auto relative z-10">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Image/Visual -->
        <div class="order-2 lg:order-1 scroll-reveal">
          <div class="relative rounded-3xl overflow-hidden shadow-2xl">
            <!-- Factory image -->
            <img 
              src="/nha-may.png" 
              alt="Quang Minh Factory - 3,000m² at Nguyen Khe Industrial Park, Dong Anh, Hanoi"
              class="w-full h-full object-cover aspect-[4/3]"
              loading="eager"
              fetchpriority="high"
            />
            <!-- Stats overlay -->
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-6">
              <div class="grid grid-cols-3 gap-4 text-white text-center">
                <div>
                  <div class="text-2xl font-bold">3,000m²</div>
                  <div class="text-xs opacity-90">Area</div>
                </div>
                <div>
                  <div class="text-2xl font-bold">3</div>
                  <div class="text-xs opacity-90">Production lines</div>
                </div>
                <div>
                  <div class="text-2xl font-bold">50+</div>
                  <div class="text-xs opacity-90">Employees</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Content -->
        <div class="order-1 lg:order-2 scroll-reveal">
          <div class="inline-flex items-center gap-2 bg-primary/10 text-primary px-4 py-2 rounded-full text-sm font-bold mb-6">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v3.57A22.952 22.952 0 0110 13a22.95 22.95 0 01-8-1.43V8a2 2 0 012-2h2zm2-1a1 1 0 011-1h2a1 1 0 011 1v1H8V5zm1 5a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1z" clip-rule="evenodd" />
              <path d="M2 13.692V16a2 2 0 002 2h12a2 2 0 002-2v-2.308A24.974 24.974 0 0110 15c-2.796 0-5.487-.46-8-1.308z" />
            </svg>
            <span>{homepageStaticEn.htmlContent.aboutQuangMinh}</span>
          </div>

          <h2 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6 leading-tight">
            {homepageStaticEn.htmlContent.companyIntroTitle}
          </h2>

          <p class="text-xl text-gray-600 mb-8 leading-relaxed">
            {companyInfo.brand} is a direct manufacturer of aluminum structures and solar accessories, 
            with a {companyInfo.capacity.factoryArea} factory at {companyInfo.capacity.location}. 
            We specialize in providing complete solutions for large-scale EPC projects.
          </p>

          <!-- Key Points -->
          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Factory {companyInfo.capacity.factoryArea}</h3>
                <p class="text-gray-600">{companyInfo.capacity.productionLines}, meeting {companyInfo.capacity.monthlyCapacity} projects</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Closed Process</h3>
                <p class="text-gray-600">From mold design, extrusion, surface treatment to CNC machining and QC</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">Professional Team</h3>
                <p class="text-gray-600">{companyInfo.capacity.engineers} and {companyInfo.capacity.employees}, MWp project experience</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-orange-50 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-gray-900 mb-1">{homepageStaticEn.htmlContent.isoTitle}</h3>
                <p class="text-gray-600">{homepageStaticEn.htmlContent.isoDescription}</p>
              </div>
            </div>
          </div>

          <!-- CTA -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a 
              href="/en/about"
              class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary-dark text-white px-8 py-4 rounded-full font-semibold text-lg shadow-lg hover:shadow-xl transition-all"
            >
              <span>{homepageStaticEn.htmlContent.learnMore}</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
            <a 
              href="/en/contact"
              class="inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-900 px-8 py-4 rounded-full font-semibold text-lg border-2 border-gray-300 hover:border-gray-400 transition-all"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              <span>{homepageStaticEn.htmlContent.contactNow}</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Certificates & Partners Combined Section -->
  <CertificatesAndPartners 
    title={homepageStaticEn.certificates.title}
    subtitle={homepageStaticEn.certificates.subtitle}
    badge={homepageStaticEn.certificates.badge}
    partnersSection={homepageContent.trustBadges}
    client:load 
  />

  <!-- Stats Section - Animated Counter -->
  <section class="py-16 md:py-20 relative overflow-hidden bg-gradient-to-b from-gray-50/40 to-white">
    <!-- Multi-layer background -->
    <div class="absolute inset-0 bg-neutral-50"></div>
    
    <!-- Animated gradient orbs -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-blue-300 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
      <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-indigo-300 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
    </div>
    
    <div class="container mx-auto px-4 relative z-10">
      <!-- Animated Counter -->
      <AnimatedCounter section={homepageContent.animatedCounter} client:visible />
    </div>
  </section>

  <!-- Products Section - Apple-Style with Category Cards - MOVED UP from position #10 -->
  <section class="py-16 md:py-20 px-4 relative overflow-hidden bg-gradient-to-b from-white to-gray-50/40">
    <!-- Base gradient -->
    <div class="absolute inset-0 bg-white" data-parallax="0.3"></div>
    
    <!-- 3D Wave Background -->
    <div class="absolute inset-0 opacity-[0.08]" data-parallax="0.5">
      <ParticleWave3D client:only="react" />
    </div>
    
    <div class="container mx-auto relative z-10">
      <div class="text-center mb-16 scroll-reveal">
        <h2 class="text-5xl md:text-6xl font-semibold text-gray-900 mb-6 tracking-tight">{homepageStaticEn.htmlContent.productsTitle}</h2>
