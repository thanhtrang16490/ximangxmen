---
import BaseLayout from '../../layouts/BaseLayout.astro'
import GeneralQuoteModal from '../../components/GeneralQuoteModal.astro'
import { caseStudiesEn } from '../../data/case-studies'

const seoTitle = "Projects - Quang Minh | Solar Power & Industrial Aluminum Projects"
const seoDescription = "Explore Quang Minh's featured solar power and industrial aluminum projects. Over 500+ successfully completed projects with a total capacity of 100+ MWp nationwide."
const seoKeywords = [
  "solar power projects",
  "industrial aluminum projects",
  "solar mounting systems",
  "rooftop solar systems",
  "renewable energy projects",
  "Quang Minh projects"
]

// Project categories for filtering
const categories = [
  { id: 'all', name: 'All', count: caseStudiesEn.length },
  { id: 'solar', name: 'Solar Energy', count: caseStudiesEn.filter(p => p.industry?.includes('Renewable') || p.industry?.includes('Energy')).length },
  { id: 'industrial', name: 'Industrial', count: caseStudiesEn.filter(p => p.industry?.includes('Industrial') || p.industry?.includes('Power')).length },
  { id: 'commercial', name: 'Commercial', count: caseStudiesEn.filter(p => p.industry?.includes('Real Estate')).length }
]
---

<BaseLayout 
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  canonical="/en/projects"
>
  <!-- Hero Section -->
  <section class="pt-24 md:pt-32 pb-16 md:pb-20 bg-gradient-to-br from-blue-50 via-white to-blue-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-semibold text-gray-900 mb-6 tracking-tight leading-tight">
          Featured Projects
        </h1>
        <p class="text-lg sm:text-xl md:text-2xl text-gray-600 font-light max-w-3xl mx-auto leading-relaxed">
          Over 500+ solar power and industrial aluminum projects successfully completed
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center p-6 bg-white rounded-2xl shadow-md">
          <div class="text-3xl md:text-4xl font-bold text-primary mb-2">500+</div>
          <div class="text-sm text-gray-700">Projects Completed</div>
        </div>
        <div class="text-center p-6 bg-white rounded-2xl shadow-md">
          <div class="text-3xl md:text-4xl font-bold text-green-600 mb-2">100+</div>
          <div class="text-sm text-gray-700">MWp Installed</div>
        </div>
        <div class="text-center p-6 bg-white rounded-2xl shadow-md">
          <div class="text-3xl md:text-4xl font-bold text-purple-600 mb-2">16+</div>
          <div class="text-sm text-gray-700">Years Experience</div>
        </div>
        <div class="text-center p-6 bg-white rounded-2xl shadow-md">
          <div class="text-3xl md:text-4xl font-bold text-orange-600 mb-2">100%</div>
          <div class="text-sm text-gray-700">Satisfaction</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter Section -->
  <section class="py-8 bg-white border-b border-gray-200 sticky top-0 z-40">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <div class="flex flex-wrap gap-3 justify-center" id="project-filters">
        {categories.map((cat) => (
          <button
            data-category={cat.id}
            class="px-6 py-2.5 rounded-full text-sm font-medium transition-all duration-300 filter-btn
                   {cat.id === 'all' ? 'bg-primary text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}"
          >
            {cat.name} <span class="ml-1.5 opacity-75">({cat.count})</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Case Studies Section -->
  <section class="py-20 md:py-24 bg-white">
    <div class="max-w-[1200px] mx-auto px-4 sm:px-6">
      <div class="space-y-12" id="projects-container">
        {caseStudiesEn.map((project, index) => (
          <div 
            class="project-card bg-white rounded-3xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-500"
            data-category={project.industry?.includes('Renewable') || project.industry?.includes('Energy') ? 'solar' : project.industry?.includes('Real Estate') ? 'commercial' : 'industrial'}
          >
            <div class={`grid md:grid-cols-2 gap-8 ${index % 2 === 1 ? 'md:grid-flow-dense' : ''}`}>
              <!-- Image -->
              <div class={`relative h-64 md:h-full min-h-[400px] bg-gradient-to-br from-blue-500 to-primary ${index % 2 === 1 ? 'md:col-start-2' : ''}`}>
                <div class="absolute inset-0 flex items-center justify-center">
                  <svg class="w-24 h-24 text-white opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
                  </svg>
                </div>
                <div class="absolute top-4 left-4">
                  <span class="px-4 py-2 bg-white/90 backdrop-blur-sm rounded-full text-sm font-semibold text-primary">
                    {project.capacity}
                  </span>
                </div>
              </div>

              <!-- Content -->
              <div class="p-8 md:p-10 flex flex-col justify-center">
                <div class="text-xs font-semibold text-primary mb-2 uppercase tracking-wider">{project.industry}</div>
                <h3 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-4">{project.title}</h3>
                
                <div class="space-y-4 mb-6">
                  <div class="flex items-start gap-3">
                    <span class="text-gray-400 mt-1">📍</span>
                    <div>
                      <div class="text-sm font-medium text-gray-900">{project.client}</div>
                      <div class="text-sm text-gray-600">{project.location}</div>
                    </div>
                  </div>
                </div>

                <div class="mb-6">
                  <h4 class="text-sm font-semibold text-gray-900 mb-2">Challenge</h4>
                  <p class="text-sm text-gray-600 leading-relaxed">{project.challenge}</p>
                </div>

                <div class="mb-6">
                  <h4 class="text-sm font-semibold text-gray-900 mb-2">Solution</h4>
                  <p class="text-sm text-gray-600 leading-relaxed">{project.solution}</p>
                </div>

                <!-- Results -->
                {project.results && (
                  <div class="grid grid-cols-3 gap-4 mb-6">
                    {project.results.map((result) => (
                      <div class="text-center p-3 bg-gray-50 rounded-xl">
                        <div class="text-2xl mb-1">{result.icon}</div>
                        <div class="text-lg font-bold text-gray-900">{result.value}</div>
                        <div class="text-xs text-gray-600">{result.label}</div>
                      </div>
                    ))}
                  </div>
                )}

                <!-- Testimonial -->
                {project.testimonial && (
                  <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl p-5">
                    <p class="text-sm text-gray-700 italic mb-3">"{project.testimonial.quote}"</p>
                    <div class="text-xs font-semibold text-gray-900">{project.testimonial.author}</div>
                    <div class="text-xs text-gray-600">{project.testimonial.role}</div>
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-[692px] mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl sm:text-4xl font-semibold text-gray-900 mb-4 tracking-tight">
        Start Your Project
      </h2>
      <p class="text-[17px] text-gray-600 mb-8 font-light">
        Contact us for optimal solutions for your project
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <button 
          id="quote-cta-button"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary hover:bg-primary-dark text-white rounded-xl text-[15px] font-medium transition-all"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Request Quote
        </button>
        <a 
          href="tel:+84947776662"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white hover:bg-gray-50 text-gray-900 rounded-xl text-[15px] font-medium transition-all border border-gray-200"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call: 0947 776 662
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<!-- Quote Modal -->
<GeneralQuoteModal />

<script>
  // Filter functionality
  const filterButtons = document.querySelectorAll('.filter-btn')
  const projectCards = document.querySelectorAll('.project-card')

  filterButtons.forEach(button => {
    button.addEventListener('click', () => {
      const category = button.getAttribute('data-category')
      
      // Update active button
      filterButtons.forEach(btn => {
        btn.classList.remove('bg-primary', 'text-white')
        btn.classList.add('bg-gray-100', 'text-gray-700')
      })
      button.classList.remove('bg-gray-100', 'text-gray-700')
      button.classList.add('bg-primary', 'text-white')

      // Filter projects
      projectCards.forEach(card => {
        const cardCategory = card.getAttribute('data-category')
        if (category === 'all' || cardCategory === category) {
          card.style.display = ''
          card.classList.add('animate-fade-in')
        } else {
          card.style.display = 'none'
        }
      })
    })
  })
</script>

<style>
  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fade-in 0.5s ease-out;
  }
</style>
