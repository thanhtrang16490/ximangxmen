        <a 
          href="/san-pham"
          class="magnetic-button group bg-primary hover:bg-primary-dark text-white px-10 py-5 rounded-full font-bold text-lg transition-all inline-flex items-center justify-center gap-3 shadow-xl hover:shadow-2xl hover:scale-105 transform"
