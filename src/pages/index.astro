---
import BaseLayout from '../layouts/BaseLayout.astro'
import ScrollProgress from '../components/ScrollProgress.astro'
import { companyInfo } from '../data/company-info'

const seoTitle = "Xi Măng Chống Thấm CX-MEN Chính Hãng | Thách Thức Mọi Thời Tiết"
const seoDescription = "Xi măng chống thấm CX-MEN PCB 40 – công nghệ siêu kỵ nước, chống thấm vĩnh cửu. Dùng cho sàn mái, nhà vệ sinh, bể nước, tường ngoài. Hotline: 0919.229.227. Giao hàng toàn quốc."
const seoKeywords = ["xi măng chống thấm CX-MEN","xi măng chống thấm chính hãng","xi măng pooclang PCB 40","chống thấm sàn mái","chống thấm nhà vệ sinh","chống thấm bể nước","vữa chống thấm","xi măng chống thấm Hà Nội"]

const testimonials = [
  {
    name: "Anh Nguyễn Văn Hùng",
    project: "Sàn mái nhà 3 tầng – Hà Đông",
    avatar: "👨‍💼",
    rating: 5,
    quote: "Sàn mái nhà tôi bị thấm nước mỗi khi mưa to. Sau khi dùng xi măng CX-MEN để cán lại, đã hết thấm hoàn toàn. Sản phẩm chất lượng, thi công đơn giản.",
    result: "Hết thấm hoàn toàn"
  },
  {
    name: "Chị Trần Thị Lan",
    project: "Nhà vệ sinh & ban công – Thanh Xuân",
    avatar: "👩‍💼",
    rating: 5,
    quote: "Nhà vệ sinh và ban công bị thấm nhiều năm. Sau khi dùng CX-MEN trát lại, hết thấm hoàn toàn. Rất hài lòng với sản phẩm và dịch vụ tư vấn.",
    result: "Bền lâu, không bong tróc"
  },
  {
    name: "Anh Phạm Minh Tuấn",
    project: "Bể nước gia đình 5m³ – Cầu Giấy",
    avatar: "🧑‍💼",
    rating: 5,
    quote: "Bể nước bị thấm, nước luôn hao hụt. Dùng CX-MEN trát lại bể, giờ không còn thấm nữa. Dễ dùng, hiệu quả cao.",
    result: "Chống thấm hiệu quả"
  }
]

const faqs = [
  { question: "Xi măng CX-MEN là gì?", answer: "CX-MEN là xi măng Pooclang PCB 40 đa dụng cao cấp, sản xuất bởi Công ty Cổ phần Mozart Việt Nam. Với công nghệ siêu kỵ nước (hiệu ứng lá sen), chống thấm vĩnh cửu theo tuổi thọ công trình." },
  { question: "CX-MEN dùng cho những hạng mục nào?", answer: "Sàn mái, sân thượng, ban công, nhà vệ sinh, bể nước, bể cá, hồ bơi, phần ngầm, tường ngoài, chân tường tầng 1, khe tiếp giáp giữa 2 nhà và mọi hạng mục cần chống thấm." },
  { question: "Cấp phối vữa CX-MEN như thế nào?", answer: "Vữa M100: 1 bao CX-MEN (25kg) + 3 xô cát 18L. Vữa M75: 1 bao CX-MEN (25kg) + 5 xô cát 18L. Trộn bằng máy 3-5 phút, không trộn thủ công." },
  { question: "Kết quả kiểm nghiệm như thế nào?", answer: "Cường độ nén tỷ lệ 1:1 đạt ~30,81 N/mm². Độ chống thấm (TCVN 3116:2022): 0/6 mẫu thấm ở tất cả cấp áp lực từ 2 đến 19 daN/cm² – chứng minh khả năng kháng nước tuyệt đối." },
  { question: "Giá xi măng CX-MEN bao nhiêu?", answer: "Liên hệ hotline 0919.229.227 để được báo giá tốt nhất. Cam kết giá cạnh tranh, giao hàng nhanh toàn quốc." },
  { question: "Thời gian giao hàng bao lâu?", answer: "Nội thành Hà Nội giao trong ngày. Các tỉnh thành khác 1-3 ngày. Giao hàng tận nơi, miễn phí vận chuyển cho đơn hàng lớn." },
  { question: "Có hỗ trợ kỹ thuật thi công không?", answer: "Có. Hỗ trợ kỹ thuật 24/7 qua hotline 0919.229.227. Cung cấp hướng dẫn thi công chi tiết và tư vấn phương án chống thấm miễn phí." }
]

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
  }))
}

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Xi Măng Chống Thấm CX-MEN",
  "description": "Xi măng Pooclang PCB 40 đa dụng cao cấp, công nghệ siêu kỵ nước, chống thấm vĩnh cửu.",
  "brand": { "@type": "Brand", "name": "CX-MEN" },
  "offers": { "@type": "Offer", "priceCurrency": "VND", "availability": "https://schema.org/InStock" },
  "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.9", "reviewCount": "500" }
}
---

<BaseLayout title={seoTitle} description={seoDescription} keywords={seoKeywords} ogImage="/nha-may.png" canonical="/">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <ScrollProgress />

  <div class="min-h-screen bg-white">

  <!-- ===== HERO ===== -->
  <section class="min-h-[85vh] flex items-center justify-center px-4 pt-20 pb-16 relative overflow-hidden bg-gradient-to-br from-slate-50 via-white to-blue-50/30">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-blue-300 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-red-200 rounded-full mix-blend-multiply filter blur-3xl animate-blob" style="animation-delay:2s"></div>
    </div>
    <div class="container mx-auto text-center relative z-10 max-w-5xl">
      <!-- Badge -->
      <div class="mb-6">
        <span class="inline-flex items-center gap-2 bg-red-600 text-white px-5 py-2 rounded-full text-sm font-bold shadow">
          ⭐ 24+ năm kinh nghiệm • 10,000+ công trình tin dùng
        </span>
      </div>

      <!-- Headline -->
      <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold text-gray-900 mb-4 leading-tight tracking-tight">
        Xi Măng Chống Thấm<br/>
        <span class="text-red-600">CX-MEN</span> Chính Hãng
      </h1>
      <p class="text-xl md:text-2xl font-semibold text-gray-600 mb-3">THÁCH THỨC MỌI THỜI TIẾT</p>
      <p class="text-lg md:text-xl text-gray-600 mb-8 max-w-3xl mx-auto leading-relaxed">
        Công nghệ siêu kỵ nước – hiệu ứng lá sen. Chống thấm vĩnh cửu theo tuổi thọ công trình.<br/>
        Kiểm nghiệm TCVN: <strong>0/6 mẫu thấm</strong> ở áp lực 2–19 daN/cm².
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
        <a href="tel:0919229227" class="group bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-full font-bold text-lg transition-all inline-flex items-center justify-center gap-3 shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          Gọi ngay: 0919.229.227
        </a>
        <a href="#san-pham" class="group bg-white hover:bg-gray-50 text-gray-900 px-8 py-4 rounded-full font-bold text-lg border-2 border-gray-300 hover:border-gray-400 transition-all inline-flex items-center justify-center gap-2 shadow hover:shadow-md">
          Xem sản phẩm
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>

      <!-- Trust bar -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 max-w-3xl mx-auto">
        {[
          { icon: "✅", label: "Sản phẩm chính hãng" },
          { icon: "🧪", label: "Kiểm nghiệm TCVN" },
          { icon: "🚚", label: "Giao hàng toàn quốc" },
          { icon: "📞", label: "Hỗ trợ kỹ thuật 24/7" }
        ].map(item => (
          <div class="bg-white/90 backdrop-blur rounded-xl p-3 shadow border border-gray-100 text-center">
            <div class="text-2xl mb-1">{item.icon}</div>
            <div class="text-xs font-semibold text-gray-700">{item.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ===== SẢN PHẨM / ỨNG DỤNG ===== -->
  <section id="san-pham" class="py-16 md:py-20 px-4 bg-gray-50">
    <div class="container mx-auto max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">Ứng Dụng Xi Măng CX-MEN</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">Một sản phẩm – giải pháp chống thấm toàn diện cho mọi hạng mục công trình</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { icon: "🏠", title: "Sàn mái & Sân thượng", desc: "Cán vữa chống thấm sàn mái, sân thượng, ban công. Chống thấm hoàn hảo, không co ngót, rạn nứt.", tag: "Phổ biến nhất" },
          { icon: "🚿", title: "Nhà vệ sinh & Ban công", desc: "Trát vữa chống thấm nhà vệ sinh, ban công, lô gia. Chống thấm thuận và nghịch cực tốt.", tag: "" },
          { icon: "💧", title: "Bể nước & Hồ bơi", desc: "Chống thấm bể nước, bể cá, hồ bơi, hố pit. An toàn với nước sinh hoạt, chống kiềm hóa.", tag: "" },
          { icon: "🧱", title: "Tường ngoài & Phần ngầm", desc: "Xây trát tường ngoài, chân tường tầng 1, phần ngầm. Chống thấm ngược từ đất hiệu quả.", tag: "" },
          { icon: "🔧", title: "Khe nứt & Tiếp giáp", desc: "Xử lý khe tiếp giáp giữa 2 nhà, khe nứt tường. Bám dính tốt, không co ngót.", tag: "" },
          { icon: "🏗️", title: "Đổ bê tông chống thấm", desc: "Xi măng PCB 40 đa dụng cho đổ bê tông. Cường độ sớm cao, tháo ván khuôn sớm hơn.", tag: "" }
        ].map(item => (
          <div class="bg-white rounded-2xl p-6 shadow-sm hover:shadow-md transition-all border border-gray-100 hover:-translate-y-1">
            <div class="text-4xl mb-4">{item.icon}</div>
            <div class="flex items-center gap-2 mb-2">
              <h3 class="text-lg font-bold text-gray-900">{item.title}</h3>
              {item.tag && <span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full font-semibold">{item.tag}</span>}
            </div>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="tel:0919229227" class="inline-flex items-center gap-2 bg-red-600 hover:bg-red-700 text-white px-8 py-4 rounded-full font-bold text-lg transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          Tư vấn miễn phí: 0919.229.227
        </a>
      </div>
    </div>
  </section>


  <!-- ===== TẠI SAO CHỌN CX-MEN ===== -->
  <section class="py-16 md:py-20 px-4 bg-white">
    <div class="container mx-auto max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">Tại Sao Chọn CX-MEN?</h2>
        <p class="text-lg text-gray-600">Được kiểm nghiệm theo tiêu chuẩn TCVN – kết quả nói lên tất cả</p>
      </div>
      <div class="grid md:grid-cols-2 gap-8 items-center">
        <!-- Left: Key features -->
        <div class="space-y-5">
          {[
            { icon: "🌿", title: "Công nghệ siêu kỵ nước – Hiệu ứng Lá Sen", desc: "Tạo lớp bảo vệ trên bề mặt và trong toàn khối vữa. Nước không thể thấm qua ở bất kỳ điều kiện nào." },
            { icon: "🔬", title: "Kiểm nghiệm TCVN – 0/6 mẫu thấm", desc: "Đạt kết quả tuyệt đối ở áp lực 2–19 daN/cm². Cường độ nén ~30,81 N/mm² (tỷ lệ 1:1)." },
            { icon: "🧱", title: "Nguyên khối liên kết – Không tách lớp", desc: "Tạo khối liên kết bền chặt với nền, không xảy ra tình trạng bong tróc hay tách lớp theo thời gian." },
            { icon: "⚡", title: "Cường độ sớm cao – Thi công nhanh", desc: "Vữa khô đặc và chắc hơn, cho phép tháo ván khuôn sớm, rút ngắn thời gian thi công đáng kể." },
            { icon: "🛡️", title: "Chống nồm ẩm, kiềm hóa và muối tuyết", desc: "Bảo vệ toàn diện trước các tác nhân ăn mòn. Tuổi thọ vĩnh cửu theo tuổi thọ công trình." }
          ].map(item => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-12 h-12 bg-red-50 rounded-xl flex items-center justify-center text-2xl">{item.icon}</div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1">{item.title}</h3>
                <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
        <!-- Right: Stats + CTA -->
        <div class="bg-gradient-to-br from-red-600 to-red-700 rounded-3xl p-8 text-white">
          <h3 class="text-2xl font-bold mb-6">Kết Quả Thực Tế</h3>
          <div class="grid grid-cols-2 gap-4 mb-8">
            {[
              { num: "10,000+", label: "Công trình hoàn thành" },
              { num: "24+", label: "Năm kinh nghiệm" },
              { num: "0/6", label: "Mẫu thấm (TCVN)" },
              { num: "30.81", label: "N/mm² cường độ nén" }
            ].map(s => (
              <div class="bg-white/15 rounded-2xl p-4 text-center">
                <div class="text-3xl font-bold mb-1">{s.num}</div>
                <div class="text-sm opacity-90">{s.label}</div>
              </div>
            ))}
          </div>
          <div class="space-y-3">
            <a href="tel:0919229227" class="w-full bg-white text-red-600 hover:bg-gray-50 px-6 py-3 rounded-full font-bold text-center transition-all block hover:-translate-y-0.5 shadow">
              📞 Gọi ngay: 0919.229.227
            </a>
            <a href="https://zalo.me/0919229227" class="w-full bg-white/20 hover:bg-white/30 text-white px-6 py-3 rounded-full font-semibold text-center transition-all block border border-white/30">
              💬 Nhắn Zalo tư vấn
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ===== HƯỚNG DẪN SỬ DỤNG ===== -->
  <section class="py-16 md:py-20 px-4 bg-gray-50">
    <div class="container mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">Cách Thi Công CX-MEN</h2>
        <p class="text-lg text-gray-600">Đơn giản như xi măng thường – hiệu quả vượt trội</p>
      </div>
      <!-- Cấp phối -->
      <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-gray-100 mb-8">
        <h3 class="text-xl font-bold text-gray-900 mb-4">📊 Bảng Cấp Phối Vữa</h3>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-red-50">
                <th class="text-left p-3 font-bold text-gray-900 rounded-tl-lg">Vật liệu</th>
                <th class="text-center p-3 font-bold text-gray-900">Vữa M100</th>
                <th class="text-center p-3 font-bold text-gray-900 rounded-tr-lg">Vữa M75</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-t border-gray-100">
                <td class="p-3 font-semibold text-gray-800">Xi măng CX-MEN</td>
                <td class="p-3 text-center text-gray-700">1 bao (25kg)</td>
                <td class="p-3 text-center text-gray-700">1 bao (25kg)</td>
              </tr>
              <tr class="border-t border-gray-100 bg-gray-50">
                <td class="p-3 font-semibold text-gray-800">Cát sạch</td>
                <td class="p-3 text-center text-gray-700">3 xô 18L</td>
                <td class="p-3 text-center text-gray-700">5 xô 18L</td>
              </tr>
              <tr class="border-t border-gray-100">
                <td class="p-3 font-semibold text-gray-800">Ứng dụng</td>
                <td class="p-3 text-center text-gray-700">Sàn mái, bể nước, WC</td>
                <td class="p-3 text-center text-gray-700">Tường xây, trát nhẹ</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="text-sm text-gray-500 mt-3">⚠️ Trộn bằng máy 3–5 phút. Không trộn thủ công. Trộn cát ẩm trước, sau đó thêm nước vừa đủ.</p>
      </div>
      <!-- Steps -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { step: "1", title: "Chuẩn bị bề mặt", desc: "Loại bỏ bê tông yếu, tạp chất. Gia cố cổ ống, xử lý vết nứt." },
          { step: "2", title: "Làm ẩm & trải lưới", desc: "Làm ẩm bề mặt (không đọng nước). Trải lưới thủy tinh toàn bộ diện tích." },
          { step: "3", title: "Thi công vữa CX-MEN", desc: "Quét hồ dầu tạo kết nối. Cán/trát vữa CX-MEN lên toàn bộ diện tích." },
          { step: "4", title: "Bảo dưỡng & kiểm tra", desc: "Không đi lại 48h đầu. Sau 24–48h bơm nước ngâm kiểm tra thấm." }
        ].map(item => (
          <div class="bg-white rounded-2xl p-5 shadow-sm border border-gray-100 text-center">
            <div class="w-10 h-10 bg-red-600 text-white rounded-full flex items-center justify-center font-bold text-lg mx-auto mb-3">{item.step}</div>
            <h3 class="font-bold text-gray-900 mb-2">{item.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- ===== ĐÁNH GIÁ KHÁCH HÀNG ===== -->
  <section class="py-16 md:py-20 px-4 bg-white">
    <div class="container mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">Khách Hàng Nói Gì?</h2>
        <p class="text-lg text-gray-600">Hơn 10,000 gia đình đã tin dùng CX-MEN</p>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {testimonials.map(t => (
          <div class="bg-gray-50 rounded-2xl p-6 border border-gray-100">
            <div class="flex items-center gap-1 mb-3">
              {Array(t.rating).fill(0).map(() => <span class="text-yellow-400 text-lg">★</span>)}
            </div>
            <p class="text-gray-700 text-sm leading-relaxed mb-4 italic">"{t.quote}"</p>
            <div class="border-t border-gray-200 pt-4">
              <div class="flex items-center gap-3">
                <span class="text-3xl">{t.avatar}</span>
                <div>
