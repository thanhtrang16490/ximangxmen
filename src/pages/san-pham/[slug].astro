---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getProductBySlug, getProducts, getCategories } from '../../lib/supabase'
import GeneralQuoteModal from '../../components/GeneralQuoteModal.astro'

// Generate static paths for all products
export async function getStaticPaths() {
  const products = await getProducts()
  return products.map(product => ({
    params: { slug: product.slug },
  }))
}

const { slug } = Astro.params

if (!slug) {
  return Astro.redirect('/san-pham')
}

const product = await getProductBySlug(slug)

if (!product) {
  return Astro.redirect('/san-pham')
}

// Get categories for display
const categories = await getCategories()
const productCategory = categories.find(c => c.id === product.category_id)

// Get related products (same category)
const allProducts = await getProducts()
const relatedProducts = allProducts
  .filter(p => p.category_id === product.category_id && p.id !== product.id)
  .slice(0, 4)

function formatPrice(price: number): string {
  return new Intl.NumberFormat('vi-VN').format(price)
}

// SEO: Generate keywords from product data
const generateKeywords = () => {
  const keywords = [
    product.name,
    productCategory?.name || '',
    'nhôm A6005',
    'nhôm công nghiệp',
    'phụ kiện năng lượng mặt trời',
    'Quang Minh',
    'nhôm chất lượng cao'
  ]
  if (product.code) keywords.push(product.code)
  return keywords.filter(Boolean)
}

// SEO: Generate rich description
const seoDescription = product.description 
  ? `${product.description.slice(0, 150)}... | Quang Minh - Nhà sản xuất nhôm A6005 hàng đầu Việt Nam`
  : `${product.name} - Sản phẩm nhôm công nghiệp chất lượng cao từ Quang Minh. Liên hệ 0947 776 662 để nhận báo giá tốt nhất.`

// SEO: Structured Data - Product Schema
const productSchema = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": product.name,
  "image": product.image_url || `${Astro.url.origin}/appejv-logo.png`,
  "description": product.description || `${product.name} - Sản phẩm chất lượng cao từ Quang Minh`,
  "sku": product.code || product.slug,
  "brand": {
    "@type": "Brand",
    "name": "Quang Minh"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Công ty Cổ phần Nhôm Quang Minh"
  },
  ...(product.price !== null && {
    "offers": {
      "@type": "Offer",
      "url": `${Astro.url.origin}/san-pham/${product.slug}`,
      "priceCurrency": "VND",
      "price": product.price,
      "priceValidUntil": new Date(Date.now() + 90 * 24 * 60 * 60 * 1000).toISOString().split('T')[0],
      "availability": "https://schema.org/InStock",
      "seller": {
        "@type": "Organization",
        "name": "Quang Minh"
      }
    }
  }),
  ...(productCategory && {
    "category": productCategory.name
  })
}

// SEO: Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Trang chủ",
      "item": Astro.url.origin
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Sản phẩm",
      "item": `${Astro.url.origin}/san-pham`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": product.name,
      "item": `${Astro.url.origin}/san-pham/${product.slug}`
    }
  ]
}
---

<BaseLayout 
  title={`${product.name} | Nhôm A6005 Quang Minh - Giá Tốt Nhất 2026`}
  description={seoDescription}
  keywords={generateKeywords()}
  canonical={`/san-pham/${product.slug}`}
  ogImage={product.image_url || '/appejv-logo.png'}
>
  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- Breadcrumb -->
  <nav class="pt-20 pb-4 bg-white border-b border-gray-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2 text-[13px] overflow-x-auto scrollbar-hide min-h-[20px]">
        <a href="/" class="text-gray-600 hover:text-gray-900 transition-colors whitespace-nowrap flex-shrink-0 inline-flex items-center">Trang chủ</a>
        <svg class="w-3 h-3 text-gray-400 flex-shrink-0 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <a href="/san-pham" class="text-gray-600 hover:text-gray-900 transition-colors whitespace-nowrap flex-shrink-0 inline-flex items-center">Sản phẩm</a>
        <svg class="w-3 h-3 text-gray-400 flex-shrink-0 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        <span class="text-gray-900 truncate inline-flex items-center">{product.name}</span>
      </div>
    </div>
  </nav>

  <!-- Product Detail -->
  <article class="py-12 md:py-16 bg-white" itemscope itemtype="https://schema.org/Product">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
        <!-- Product Image -->
        <div class="order-1">
          <div class="aspect-square bg-[#f5f5f7] rounded-2xl flex items-center justify-center p-8 md:p-12 sticky top-24">
            {product.image_url ? (
              <img 
                src={product.image_url} 
                alt={`${product.name} - ${productCategory?.name || 'Sản phẩm'} chất lượng cao từ Quang Minh`}
                title={product.name}
                class="w-full h-full object-contain"
                itemprop="image"
              />
            ) : (
              <svg class="w-32 h-32 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-label="Hình ảnh sản phẩm">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
              </svg>
            )}
          </div>
        </div>

        <!-- Product Info -->
        <div class="order-2">
          {productCategory && (
            <div class="text-[13px] font-medium text-[#175ead] mb-2 uppercase tracking-wide" itemprop="category">
              {productCategory.name}
            </div>
          )}
          
          <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold text-gray-900 mb-4 tracking-tight leading-tight" itemprop="name">
            {product.name}
          </h1>
          
          {product.code && (
            <div class="text-[13px] text-gray-600 mb-6">
              Mã: <span class="font-mono" itemprop="sku">{product.code}</span>
            </div>
          )}
          
          {product.description && (
            <p class="text-[17px] text-gray-600 mb-8 leading-relaxed" itemprop="description">
              {product.description}
            </p>
          )}

          {/* Price */}
          <div class="mb-8 pb-8 border-b border-gray-200" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
            <meta itemprop="priceCurrency" content="VND" />
            <meta itemprop="availability" content="https://schema.org/InStock" />
            <link itemprop="url" href={`${Astro.url.origin}/san-pham/${product.slug}`} />
            {product.price !== null ? (
              <>
                <div class="flex items-baseline gap-2 mb-1">
                  <span class="text-4xl font-semibold text-gray-900" itemprop="price" content={product.price.toString()}>
                    {formatPrice(product.price)}đ
                  </span>
                  {product.unit && (
                    <span class="text-[17px] text-gray-600">
                      /{product.unit}
                    </span>
                  )}
                </div>
                <p class="text-[13px] text-gray-500">Giá đã bao gồm VAT</p>
              </>
            ) : (
              <>
                <div class="mb-2">
                  <span class="text-3xl font-semibold text-blue-600">
                    Liên hệ để báo giá
                  </span>
                </div>
                <p class="text-[15px] text-gray-600">
                  Vui lòng liên hệ để nhận báo giá chi tiết cho sản phẩm này
                </p>
              </>
            )}
          </div>

          {/* Specifications */}
          {product.specifications && (
            <div class="mb-8 pb-8 border-b border-gray-200">
              <h2 class="text-[17px] font-semibold text-gray-900 mb-4">Thông số kỹ thuật</h2>
              <div class="text-[15px] text-gray-600 leading-relaxed whitespace-pre-line">
                {product.specifications}
              </div>
            </div>
          )}

          {/* Features */}
          <div class="mb-8 space-y-3">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-[15px] text-gray-900">Chất lượng đảm bảo</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-[15px] text-gray-900">Mua qua 150+ đại lý toàn quốc</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-[15px] text-gray-900">Hỗ trợ kỹ thuật chuyên nghiệp</span>
            </div>
          </div>

          {/* CTA Buttons */}
          <div class="flex flex-col sm:flex-row gap-3">
            <button 
              id="quote-button"
              class="flex-1 inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-6 py-3 rounded-xl text-[15px] font-medium transition-all"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Nhận báo giá
            </button>
            <a 
              href="tel:+84947776662"
              class="flex-1 inline-flex items-center justify-center gap-2 bg-white hover:bg-gray-50 text-gray-900 px-6 py-3 rounded-xl text-[15px] font-medium transition-all border border-gray-200"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Gọi ngay
            </a>
          </div>
        </div>
      </div>
    </div>
  </article>

  {/* Related Products */}
  {relatedProducts.length > 0 && (
    <section class="py-12 md:py-16 bg-[#f5f5f7]" aria-label="Sản phẩm liên quan">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 mb-8 tracking-tight">
          Sản phẩm liên quan
        </h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
          {relatedProducts.map((relatedProduct) => (
            <article class="group bg-white rounded-2xl overflow-hidden hover:shadow-lg transition-all duration-300">
              <a href={`/san-pham/${relatedProduct.slug}`} class="block">
                <div class="aspect-square bg-[#f5f5f7] overflow-hidden">
                  {relatedProduct.image_url ? (
                    <img 
                      src={relatedProduct.image_url} 
                      alt={`${relatedProduct.name} - ${productCategory?.name || 'Sản phẩm'} Quang Minh`}
                      title={relatedProduct.name}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full flex items-center justify-center">
                      <svg class="w-16 h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-label="Hình ảnh sản phẩm">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                      </svg>
                    </div>
                  )}
                </div>
                <div class="p-4">
                  <h3 class="text-[15px] font-semibold text-gray-900 mb-1 line-clamp-2 group-hover:text-blue-600 transition-colors">
                    {relatedProduct.name}
                  </h3>
                  <div class="flex items-baseline gap-2">
                    {relatedProduct.price !== null ? (
                      <>
                        <span class="text-[17px] font-semibold text-gray-900">
                          {formatPrice(relatedProduct.price)}đ
                        </span>
                        {relatedProduct.unit && (
                          <span class="text-[13px] text-gray-500">
                            /{relatedProduct.unit}
                          </span>
                        )}
                      </>
                    ) : (
                      <span class="text-[15px] font-medium text-blue-600">
                        Liên hệ
                      </span>
                    )}
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <style>
    /* Hide scrollbar but keep functionality */
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }

    /* Line clamp */
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  </style>

  <!-- Quote Modal -->
  <GeneralQuoteModal products={allProducts} lang="vi" />
</BaseLayout>
