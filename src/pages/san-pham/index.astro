---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getProducts, getCategories } from '../../lib/supabase'

const seoTitle = "Sản phẩm - Quang Minh | Thanh Ray Nhôm, Kẹp Solar, Phụ Kiện A6005-T6"
const seoDescription = "Danh mục sản phẩm nhôm Quang Minh: Thanh ray nhôm A6005-T6, kẹp giữa/biên, chân L, phụ kiện tiếp địa cho hệ thống năng lượng mặt trời. Chất lượng cao, giá cạnh tranh."
const seoKeywords = [
  "thanh ray nhôm solar",
  "kẹp giữa kẹp biên",
  "chân L nhôm",
  "phụ kiện solar",
  "nhôm A6005-T6",
  "QM Solar",
  "Quang Minh",
  "rail connector",
  "seamlook clamp",
  "grounding accessories",
  "phụ kiện năng lượng mặt trời"
]

// Get query parameters
const url = new URL(Astro.request.url)
const categoryFilter = url.searchParams.get('category') || 'all'
const searchQuery = url.searchParams.get('search') || ''

// Fetch data from Supabase
const allProducts = await getProducts()
const apiCategories = await getCategories()

// Filter out products without price (null, 0, or undefined)
const productsWithPrice = allProducts.filter(p => p.price != null && p.price > 0)

const categories = [
  { id: 'all', name: 'Tất cả', icon: '🏭' },
  ...apiCategories
]

// Count products per category (only products with price)
const categoriesWithCount = categories.map(cat => {
  const count = cat.id === 'all' 
    ? productsWithPrice.length 
    : productsWithPrice.filter(p => p.category_id === cat.id).length
  return { ...cat, count }
}).filter(cat => cat.count > 0)

// Filter products
let filteredProducts = productsWithPrice

if (categoryFilter !== 'all') {
  filteredProducts = filteredProducts.filter(p => p.category_id === categoryFilter)
}

if (searchQuery) {
  filteredProducts = filteredProducts.filter(p => 
    p.name.toLowerCase().includes(searchQuery.toLowerCase())
  )
}

function formatPrice(price: number): string {
  return new Intl.NumberFormat('vi-VN').format(price)
}
---

<BaseLayout 
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  canonical="/san-pham"
>
  <!-- Hero Section - Apple Style -->
  <section class="pt-20 sm:pt-24 md:pt-32 pb-8 sm:pb-12 md:pb-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-6 sm:mb-8 md:mb-12">
        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold text-gray-900 mb-3 sm:mb-4 tracking-tight leading-tight">
          Sản phẩm
        </h1>
        <p class="text-base sm:text-lg md:text-xl lg:text-2xl text-gray-600 font-light max-w-2xl mx-auto px-4">
          Phụ kiện nhôm chất lượng cao cho hệ thống năng lượng mặt trời
        </p>
      </div>

      <!-- Search Bar -->
      <div class="max-w-[692px] mx-auto mb-6 sm:mb-8">
        <form method="get" class="relative" role="search" aria-label="Tìm kiếm sản phẩm">
          <svg class="absolute left-3 sm:left-4 top-1/2 -translate-y-1/2 w-4 h-4 sm:w-5 sm:h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input
            type="search"
            name="search"
            placeholder="Tìm kiếm sản phẩm..."
            value={searchQuery}
            aria-label="Tìm kiếm sản phẩm"
            class="w-full pl-10 sm:pl-12 pr-4 py-2.5 sm:py-3 bg-[#f5f5f7] rounded-xl text-[14px] sm:text-[15px] focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all"
          />
          <input type="hidden" name="category" value={categoryFilter} />
        </form>
      </div>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="py-4 sm:py-6 bg-white border-b border-gray-200 sticky top-[44px] z-10" role="navigation" aria-label="Lọc theo danh mục">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-2 overflow-x-auto scrollbar-hide pb-2 -mx-4 px-4 sm:mx-0 sm:px-0">
        {categoriesWithCount.map((cat) => (
          <button
            type="button"
            data-category-id={cat.id}
            aria-label={`Lọc theo ${cat.name}`}
            aria-pressed={categoryFilter === cat.id ? 'true' : 'false'}
            class={`category-filter-btn flex-shrink-0 px-3 sm:px-4 py-2 sm:py-2.5 rounded-full text-[12px] sm:text-[13px] font-medium transition-all min-h-[44px] flex items-center ${
              categoryFilter === cat.id
                ? 'bg-gray-900 text-white'
                : 'bg-[#f5f5f7] text-gray-900 hover:bg-[#e8e8ed] active:bg-[#d1d1d6]'
            }`}
          >
            <span class="mr-1 sm:mr-1.5">{cat.icon}</span>
            <span class="whitespace-nowrap">{cat.name}</span>
            <span class="ml-1 sm:ml-1.5 opacity-60 category-count">({cat.count})</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Products Grid -->
  <section class="py-8 sm:py-12 md:py-16 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Result count -->
      <div class="mb-4 sm:mb-6">
        <p class="text-[13px] sm:text-[14px] text-gray-600">
          <span class="result-count" role="status" aria-live="polite">{filteredProducts.length} sản phẩm</span>
        </p>
      </div>

      <!-- No Results Message -->
      <div id="no-results" class="text-center py-12 sm:py-16 md:py-20" style={filteredProducts.length > 0 ? 'display: none;' : ''} role="status" aria-live="polite">
        <svg class="w-16 h-16 sm:w-20 sm:h-20 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
        </svg>
        <h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-2">Không tìm thấy sản phẩm</h3>
        <p id="no-results-message" class="text-[14px] sm:text-[15px] text-gray-600 mb-6 px-4">Thử tìm kiếm với từ khóa khác hoặc chọn danh mục khác</p>
        <a href="/san-pham" class="inline-block px-6 py-3 bg-primary text-white rounded-xl text-[14px] sm:text-[15px] font-medium hover:bg-primary-dark active:bg-blue-800 transition-all min-h-[44px] flex items-center justify-center">
          Xem tất cả sản phẩm
        </a>
      </div>

      <!-- Products Grid - Mobile Optimized with Larger Images -->
      <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-2 sm:gap-4 md:gap-5 lg:gap-6" style={filteredProducts.length === 0 ? 'display: none;' : ''}>
        {filteredProducts.map((product) => (
          <a 
            href={`/san-pham/${product.slug}`}
            class="product-card group bg-white rounded-lg sm:rounded-xl overflow-hidden hover:shadow-lg active:shadow-xl transition-all duration-300 border border-gray-100 hover:border-gray-200"
            data-product-name={product.name.toLowerCase()}
            data-product-description={(product.description || '').toLowerCase()}
            data-category-id={product.category_id}
            aria-label={`Xem chi tiết ${product.name}`}
          >
            <!-- Product Image - Larger on Mobile -->
            <div class="aspect-[4/3] sm:aspect-square bg-[#f5f5f7] overflow-hidden relative">
              {product.image_url ? (
                <img 
                  src={product.image_url} 
                  alt={product.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  decoding="async"
                />
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <svg class="w-12 h-12 sm:w-12 sm:h-12 md:w-16 md:h-16 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
                  </svg>
                </div>
              )}
            </div>

            <!-- Product Info - Compact on Mobile -->
            <div class="p-1.5 sm:p-2 md:p-3 lg:p-4">
              <h3 class="text-[12px] sm:text-[13px] md:text-[14px] lg:text-[15px] font-semibold text-gray-900 mb-0.5 sm:mb-1 line-clamp-2 group-hover:text-primary transition-colors leading-tight">
                {product.name}
              </h3>
              
              {product.description && (
                <p class="text-[10px] sm:text-[11px] md:text-[12px] text-gray-600 mb-1 sm:mb-1.5 line-clamp-1 sm:line-clamp-2 leading-tight hidden sm:block">
                  {product.description}
                </p>
              )}

              <div class="flex items-baseline gap-0.5 sm:gap-1 md:gap-1.5 flex-wrap">
                {product.price !== null ? (
                  <>
                    <span class="text-[13px] sm:text-[14px] md:text-[15px] lg:text-[17px] font-bold text-gray-900">
                      {formatPrice(product.price)}đ
                    </span>
                    {product.unit && (
                      <span class="text-[10px] sm:text-[11px] md:text-[12px] text-gray-500">
                        /{product.unit}
                      </span>
                    )}
                  </>
                ) : (
                  <span class="text-[11px] sm:text-[12px] md:text-[13px] font-medium text-primary">
                    Liên hệ
                  </span>
                )}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-12 sm:py-16 md:py-20 bg-[#f5f5f7]">
    <div class="max-w-[692px] mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-semibold text-gray-900 mb-3 sm:mb-4 tracking-tight">
        Cần tư vấn?
      </h2>
      <p class="text-[15px] sm:text-[17px] text-gray-600 mb-6 sm:mb-8 font-light px-4">
        Đội ngũ chuyên gia của chúng tôi sẵn sàng hỗ trợ bạn chọn sản phẩm phù hợp
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center px-4">
        <a 
          href="tel:+84947776662"
          class="inline-flex items-center justify-center gap-2 px-5 sm:px-6 py-3 bg-primary hover:bg-primary-dark active:bg-blue-800 text-white rounded-xl text-[14px] sm:text-[15px] font-medium transition-all min-h-[44px]"
          aria-label="Gọi điện thoại 0947 776 662"
        >
          <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span class="whitespace-nowrap">Gọi ngay: 0947 776 662</span>
        </a>
        <a 
          href="/lien-he"
          class="inline-flex items-center justify-center gap-2 px-5 sm:px-6 py-3 bg-white hover:bg-gray-50 active:bg-gray-100 text-gray-900 rounded-xl text-[14px] sm:text-[15px] font-medium transition-all border border-gray-200 min-h-[44px]"
        >
          Liên hệ tư vấn
        </a>
      </div>
    </div>
  </section>

  <style>
    /* Hide scrollbar but keep functionality */
    .scrollbar-hide {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    .scrollbar-hide::-webkit-scrollbar {
      display: none;
    }

    /* Line clamp */
    .line-clamp-2 {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Smooth scroll for category filter */
    .scrollbar-hide {
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
    }

    /* Touch optimization */
    @media (hover: none) and (pointer: coarse) {
      .product-card {
        -webkit-tap-highlight-color: transparent;
      }
      
      .category-filter-btn {
        -webkit-tap-highlight-color: transparent;
      }
    }

    /* Focus visible for keyboard navigation */
    .product-card:focus-visible,
    .category-filter-btn:focus-visible {
      outline: 2px solid #3b82f6;
      outline-offset: 2px;
    }
  </style>

  <script>
    // Real-time search and category filter functionality
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.querySelector('input[name="search"]') as HTMLInputElement;
      const productsGrid = document.getElementById('products-grid') as HTMLElement;
      const noResultsDiv = document.getElementById('no-results') as HTMLElement;
      const noResultsMessage = document.getElementById('no-results-message') as HTMLElement;
      const resultCount = document.querySelector('.result-count') as HTMLElement;
      const categoryButtons = document.querySelectorAll('.category-filter-btn') as NodeListOf<HTMLButtonElement>;
      
      if (!searchInput || !productsGrid) {
        console.error('Search elements not found');
        return;
      }

      // Get all product cards
      const allProductCards = Array.from(document.querySelectorAll('.product-card')) as HTMLElement[];
      
      // Current filter state
      let currentCategory = 'all';
      let currentSearch = '';

      // Debounce function for performance
      function debounce(func: Function, wait: number) {
        let timeout: ReturnType<typeof setTimeout>;
        return function executedFunction(...args: any[]) {
          const later = () => {
            clearTimeout(timeout);
            func(...args);
          };
          clearTimeout(timeout);
          timeout = setTimeout(later, wait);
        };
      }

      // Filter and display products
      function filterProducts(searchTerm: string = currentSearch, categoryId: string = currentCategory) {
        const term = searchTerm.toLowerCase().trim();
        currentSearch = searchTerm;
        currentCategory = categoryId;
        
        let visibleCount = 0;
        
        allProductCards.forEach((card) => {
          const productName = card.getAttribute('data-product-name') || '';
          const productDesc = card.getAttribute('data-product-description') || '';
          const productCategory = card.getAttribute('data-category-id') || '';
          
          // Check search match
          const searchMatches = term === '' || 
                               productName.includes(term) || 
                               productDesc.includes(term);
          
          // Check category match
          const categoryMatches = categoryId === 'all' || productCategory === categoryId;
          
          // Show if both match
          if (searchMatches && categoryMatches) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });

        // Update result count
        if (resultCount) {
          resultCount.textContent = `${visibleCount} sản phẩm`;
        }

        // Show/hide no results message
        if (visibleCount === 0) {
          productsGrid.style.display = 'none';
          if (noResultsDiv) {
            noResultsDiv.style.display = 'block';
            if (noResultsMessage) {
              if (term) {
                noResultsMessage.textContent = `Không tìm thấy sản phẩm với từ khóa "${searchTerm}"`;
              } else {
                noResultsMessage.textContent = 'Không tìm thấy sản phẩm trong danh mục này';
              }
            }
          }
        } else {
          productsGrid.style.display = 'grid';
          if (noResultsDiv) {
            noResultsDiv.style.display = 'none';
          }
        }
      }

      // Update category button active state
      function updateCategoryButtons(activeCategoryId: string) {
        categoryButtons.forEach((btn) => {
          const btnCategoryId = btn.getAttribute('data-category-id') || '';
          if (btnCategoryId === activeCategoryId) {
            btn.classList.remove('bg-[#f5f5f7]', 'text-gray-900', 'hover:bg-[#e8e8ed]');
            btn.classList.add('bg-gray-900', 'text-white');
          } else {
            btn.classList.remove('bg-gray-900', 'text-white');
            btn.classList.add('bg-[#f5f5f7]', 'text-gray-900', 'hover:bg-[#e8e8ed]');
          }
        });
      }

      // Category filter click handlers
      categoryButtons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const categoryId = btn.getAttribute('data-category-id') || 'all';
          updateCategoryButtons(categoryId);
          filterProducts(currentSearch, categoryId);
        });
      });

      // Add real-time search with debounce
      const debouncedFilter = debounce((value: string) => {
        filterProducts(value, currentCategory);
      }, 300);

      searchInput.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        debouncedFilter(target.value);
      });

      // Handle Enter key
      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') {
          e.preventDefault();
          filterProducts(searchInput.value, currentCategory);
        }
      });

      // Clear search on Escape
      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          searchInput.value = '';
          filterProducts('', currentCategory);
        }
      });

      // Load more functionality
      const loadMoreBtn = document.getElementById('load-more');
      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', () => {
          console.log('Load more products');
        });
      }
    });
  </script>
</BaseLayout>
